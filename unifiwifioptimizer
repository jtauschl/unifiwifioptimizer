}

iface_wiphy() {
  _path=$(ensure_iface_info "$1")
  awk '/wiphy/{print $2; exit}' "$_path"
}

iface_freq() {
  _path=$(ensure_iface_info "$1")
  awk '/channel/ { gsub(/[()]/,"",$3); f=$3+0; if (f>0) print f; exit }' "$_path"
}

iface_exists() {
  _path=$(ensure_iface_info "$1")
  [ -s "$_path" ]
}

phy_has_set_scan_dwell() {
  wiphy=$(iface_wiphy "$1")
  [ -n "$wiphy" ] || return 1
  _path=$(ensure_phy_info "$wiphy")
  grep -q "SET_SCAN_DWELL" "$_path"
}

phy_supports_5g() {
  _path=$(ensure_phy_info "$1")
  awk '/\* [0-9]+ MHz/{f=$2+0; if(f>=5000&&f<5900){found=1}} END{print found+0}' "$_path"
}

# Return 0 if the interface is safe to use for scanning.
# - managed: always safe (dedicated scan interfaces like apcli0/apclii0)
# - AP: safe only if the underlying PHY advertises SET_SCAN_DWELL (Qualcomm),
#        which means AP interfaces support off-channel scanning without blocking
# - monitor and others: skip (don't touch vendor-internal interfaces like pd99)
iface_can_scan() {
  iface="$1"
  type=$(iface_type "$iface")
  case "$type" in
    managed) return 0 ;;
    AP) phy_has_set_scan_dwell "$iface" ;;
    *) return 1 ;;
  esac
}

# Return space-separated scan interface candidates for the given band.
# Tries known static names first (U6: apcli0/apclii0), then discovers
# additional candidates by matching channel frequency via iw dev.
# Only includes interfaces that pass iface_can_scan.
find_scan_candidates() {
  band="$1"
  case "$band" in
    2g) freq_min=2400; freq_max=2500; static="apcli0 apcli2" ;;
    5g) freq_min=5000; freq_max=6000; static="apclii0 apcli1 apcli3" ;;
    *) return 1 ;;
  esac

  discovered=""
  for iface in $(list_ifaces); do
    freq=$(iface_freq "$iface")
    if [ -n "$freq" ] && [ "$freq" -ge "$freq_min" ] && [ "$freq" -lt "$freq_max" ]; then
      case " $static " in
        *" $iface "*) ;;
        *) iface_can_scan "$iface" && discovered="$discovered $iface" ;;
      esac
    fi
  done

  echo "$static$discovered"
}

run_scan() {
  candidates="$1"
  outfile="$2"
  iface=""
  attempts="${SCAN_ATTEMPTS:-1}"

  case "$attempts" in
    ''|*[!0-9]*|0) attempts=1 ;;
  esac

  : > "$outfile"

  for iface in $candidates; do
    if ! iface_exists "$iface"; then
      continue
    fi
    if ! iface_can_scan "$iface"; then
      continue
    fi

    was_up=0
    if ifconfig "$iface" 2>/dev/null | grep -q "UP"; then
      was_up=1
    else
      ifconfig "$iface" up 2>/dev/null
      sleep 1
    fi

    combined_output=""
    attempt=1
    while [ "$attempt" -le "$attempts" ]; do
      scan_output=$(iw dev "$iface" scan 2>/dev/null | grep -E 'BSS|signal|SSID' || true)
      if [ -n "$scan_output" ]; then
        combined_output="${combined_output}${combined_output:+
}${scan_output}"
      fi
      [ "$attempt" -lt "$attempts" ] && sleep 1
      attempt=$((attempt + 1))
    done

    if [ "$was_up" = "0" ]; then
      ifconfig "$iface" down 2>/dev/null
    fi

    if [ -n "$combined_output" ]; then
      printf '%s\n' "$combined_output" > "$outfile"
      return 0
    fi
  done
}

# U6 devices expose reliable 5 GHz DFS/CAC progress via MediaTek kernel log
# messages. Newer platforms do not log the state as consistently, so report
# "unknown" unless the classic U6 5 GHz interface layout is present on the AP.
u6_dfs_cac_state_5g() {
  if ! iface_exists rai0 && ! iface_exists apclii0; then
    echo "unknown"
    return 0
  fi

  last_event=$(
    (logread 2>/dev/null || dmesg 2>/dev/null) \
      | grep -E '\[DfsCacEndUpdate\]\[RDM\] CAC end\. Enable MAC TX\.|\[DfsCacNormalStart\]\[RDM\] CAC [0-9]+ seconds start \. Disable MAC TX|\[DfsCacNormalStart\]\[RDM\] Normal start\. Enable MAC TX' \
      | tail -n 1
  )

  if [ -z "$last_event" ]; then
    echo "unknown"
  elif printf '%s\n' "$last_event" | grep -q 'Disable MAC TX'; then
    echo "active"
  else
    echo "ready"
  fi
}

get_device_model_name() {
  model=$(
    awk -F '=' '/^board\.name=/{print substr($0, index($0, "=") + 1); exit}' /etc/board.info 2>/dev/null
  )

  if [ -z "$model" ]; then
    model=$(
      awk -F '=' '/^name=/{print substr($0, index($0, "=") + 1); exit}' /proc/ubnthal/system.info 2>/dev/null
    )
  fi

  printf '%s\n' "$model" | tr '\t\r\n' '   ' | sed 's/[[:space:]][[:space:]]*/ /g; s/^ //; s/ $//'
}

# Return 0 if the band has at least one UP AP interface actively serving clients.
# Only scans bands where the AP is actually running a WLAN — inactive bands are
# irrelevant for roaming and should be skipped entirely.
band_is_active() {
  band="$1"
  case "$band" in
    2g) freq_min=2400; freq_max=2500 ;;
    5g) freq_min=5000; freq_max=5900 ;;
    *) return 1 ;;
  esac
  has_any=0
  for iface in $(list_ifaces); do
    has_any=1
    type=$(iface_type "$iface")
    [ "$type" = "AP" ] || continue
    freq=$(iface_freq "$iface")
    if [ -n "$freq" ]; then
      # Frequency available (newer firmware / Qualcomm) — check directly
      if [ "$freq" -ge "$freq_min" ] && [ "$freq" -lt "$freq_max" ]; then
        return 0
      fi
    else
      ifconfig "$iface" 2>/dev/null | grep -q "UP" || continue
      # No frequency in iw dev info (older MediaTek firmware does not report
      # the current channel via nl80211). Fall back to PHY capabilities:
      # a PHY that lists 5 GHz frequencies is the 5G radio; one that doesn't
      # is the 2.4G radio.
      wiphy=$(iface_wiphy "$iface")
      [ -n "$wiphy" ] || continue
      phy_has_5g=$(phy_supports_5g "$wiphy")
      case "$band" in
        2g) [ "$phy_has_5g" = "0" ] && return 0 ;;
        5g) [ "$phy_has_5g" = "1" ] && return 0 ;;
      esac
    fi
  done
  # No cfg80211 interfaces found at all — legacy AP or iw not available.
  # Cannot determine band state; proceed with scan attempt.
  [ "$has_any" = "0" ] && return 0
  return 1
}

collect_band_scan() {
  band="$1"
  outfile="$2"

  if ! band_is_active "$band"; then
    echo "===NO_RADIO===" > "$outfile"
    return 0
  fi

  scan_candidates=$(find_scan_candidates "$band")
  run_scan "$scan_candidates" "$outfile"
}

