print_footer() {
  local has_changes=$1
  local has_active_dfs_cac=${2:-false}
  if [[ "$has_changes" == "true" ]]; then
    echo
    printf "  %sAfter applying changes, please run this script again.\n" "$YELLOW"
  fi
  if [[ "$has_active_dfs_cac" == "true" ]]; then
    [[ "$has_changes" != "true" ]] && echo
    printf "  %sNote: At least one 5 GHz AP is currently in DFS CAC.\n" "$YELLOW"
    printf "  Wait until all affected access points have activated the channel\n"
    printf "  before re-running.%s\n" "$RESET"
  fi
  echo
}

print_no_neighbor_note() {
  local channel=$1 dfs_enabled=$2 cac_state=$3

  [[ "$dfs_enabled" != "true" ]] && return 0

  case "$cac_state" in
    active)
      printf "  ${YELLOW}Note: Channel %s is currently in DFS CAC on this AP — MAC TX is still disabled. Re-run after ~60s.${RESET}\n" "$channel"
      ;;
    ready)
      printf '%s\n' "  ${YELLOW}Note: DFS CAC appears complete on this AP — missing neighbor data is more likely caused by very low TX power or limited overlap.${RESET}"
      ;;
    *)
      printf "  ${YELLOW}Note: Channel %s is a DFS channel, but CAC state could not be verified on this AP.${RESET}\n" "$channel"
      ;;
  esac
}

print_group_issues() {
  local site=$1
  local section_printed=false
  local group_label members_csv
  local issues infos width24_total width5_total width24_headroom width5_headroom
  local members member i j ap_a ap_b
  local radio_info ch24 ht24 _tx24 _min_tx24 _max_tx24 _txmode24 _min_rssi24 _min_rssi_en24
  local ch5 ht5 _tx5 _min_tx5 _max_tx5 _txmode5 _min_rssi5 _min_rssi_en5 _roam_enabled _roam_rssi _ib24 _ib5 _dfs5
  local overlap_items missing_items peer_cache_a peer_cache_b
  local mac_a mac_b mac_a_band mac_b_band sight_a_to_b sight_b_to_a
  local pair_label

  while IFS=$'\t' read -r group_label members_csv; do
    [[ -z "$group_label" ]] && continue
    issues=()
    infos=()
    width24_total=0
    width5_total=0
    width24_headroom=0
    width5_headroom=0
    overlap_items=()
    missing_items=()
    IFS=',' read -r -a members <<< "$members_csv"

    for member in "${members[@]}"; do
      radio_info=$(get_radio_info "$site" "$member")
      IFS='|' read -r \
        ch24 ht24 _tx24 _min_tx24 _max_tx24 _txmode24 _min_rssi24 _min_rssi_en24 \
        ch5 ht5 _tx5 _min_tx5 _max_tx5 _txmode5 _min_rssi5 _min_rssi_en5 \
        _roam_enabled _roam_rssi _ib24 _ib5 _dfs5 <<< "$radio_info"
      [[ "$ht24" =~ ^[0-9]+$ ]] || ht24=20
      [[ "$ht5" =~ ^[0-9]+$ ]] || ht5=20
      width24_total=$(( width24_total + ht24 ))
      width5_total=$(( width5_total + ht5 ))
    done

    (( width24_total > 60 )) && issues+=("2.4 GHz width mix ${width24_total} MHz exceeds the 60 MHz clean-spectrum budget")
    (( width5_total > 320 )) && issues+=("5 GHz width mix ${width5_total} MHz exceeds the 320 MHz local-spectrum budget")

    for ((i=0; i<${#members[@]}; i++)); do
      for ((j=i+1; j<${#members[@]}; j++)); do
        ap_a=${members[i]}
        ap_b=${members[j]}
        aps_are_peers "$site" "$ap_a" "$ap_b" || continue

        radio_info=$(get_radio_info "$site" "$ap_a")
        IFS='|' read -r \
          ch24 ht24 _tx24 _min_tx24 _max_tx24 _txmode24 _min_rssi24 _min_rssi_en24 \
          ch5 ht5 _tx5 _min_tx5 _max_tx5 _txmode5 _min_rssi5 _min_rssi_en5 \
          _roam_enabled _roam_rssi _ib24 _ib5 _dfs5 <<< "$radio_info"
        radio_info=$(get_radio_info "$site" "$ap_b")
        IFS='|' read -r \
          peer_ch24 peer_ht24 _peer_tx24 _peer_min_tx24 _peer_max_tx24 _peer_txmode24 _peer_min_rssi24 _peer_min_rssi_en24 \
          peer_ch5 peer_ht5 _peer_tx5 _peer_min_tx5 _peer_max_tx5 _peer_txmode5 _peer_min_rssi5 _peer_min_rssi_en5 \
          _peer_roam_enabled _peer_roam_rssi _peer_ib24 _peer_ib5 _peer_dfs5 <<< "$radio_info"

        if channels_overlap "2g" "$ch24" "${ht24:-20}" "$peer_ch24" "${peer_ht24:-20}"; then
          overlap_items+=("2.4 GHz ${ap_a}/${ap_b}")
        fi
        if channels_overlap "5g" "$ch5" "${ht5:-20}" "$peer_ch5" "${peer_ht5:-20}"; then
          overlap_items+=("5 GHz ${ap_a}/${ap_b}")
        fi

        mac_a=$(get_ap_mac "$site" "$ap_a")
        mac_b=$(get_ap_mac "$site" "$ap_b")
        [[ -z "$mac_a" || -z "$mac_b" ]] && continue

        mac_a_band=$(mac_with_offset "$mac_a" 1)
        mac_b_band=$(mac_with_offset "$mac_b" 1)
        peer_cache_a=$(scan_rssi_cache_path "$(ap_scan_prefix "$site" "$ap_a").2g")
        peer_cache_b=$(scan_rssi_cache_path "$(ap_scan_prefix "$site" "$ap_b").2g")
        sight_a_to_b=$(get_rssi "$mac_b_band" "$peer_cache_a")
        sight_b_to_a=$(get_rssi "$mac_a_band" "$peer_cache_b")
        pair_label="2.4 GHz ${ap_a}/${ap_b}"
        if [[ -z "$sight_a_to_b" || -z "$sight_b_to_a" ]]; then
          if [[ -z "$sight_a_to_b" && -z "$sight_b_to_a" ]]; then
            missing_items+=("${pair_label} missing both directions")
          elif [[ -z "$sight_a_to_b" ]]; then
            missing_items+=("${pair_label} missing ${ap_a}->${ap_b}")
          else
            missing_items+=("${pair_label} missing ${ap_b}->${ap_a}")
          fi
        fi

        mac_a_band=$(mac_with_offset "$mac_a" 2)
        mac_b_band=$(mac_with_offset "$mac_b" 2)
        peer_cache_a=$(scan_rssi_cache_path "$(ap_scan_prefix "$site" "$ap_a").5g")
        peer_cache_b=$(scan_rssi_cache_path "$(ap_scan_prefix "$site" "$ap_b").5g")
        sight_a_to_b=$(get_rssi "$mac_b_band" "$peer_cache_a")
        sight_b_to_a=$(get_rssi "$mac_a_band" "$peer_cache_b")
        pair_label="5 GHz ${ap_a}/${ap_b}"
        if [[ -z "$sight_a_to_b" || -z "$sight_b_to_a" ]]; then
          if [[ -z "$sight_a_to_b" && -z "$sight_b_to_a" ]]; then
            missing_items+=("${pair_label} missing both directions")
          elif [[ -z "$sight_a_to_b" ]]; then
            missing_items+=("${pair_label} missing ${ap_a}->${ap_b}")
          else
            missing_items+=("${pair_label} missing ${ap_b}->${ap_a}")
          fi
        fi
      done
    done

    if (( ${#overlap_items[@]} > 0 )); then
      issues+=("overlapping adjacent channels: ${overlap_items[*]}")
    fi
    if (( ${#missing_items[@]} > 0 )); then
      issues+=("missing peer sightings: ${missing_items[*]}")
    fi

    if (( ${#issues[@]} == 0 )); then
      width24_headroom=$(( 60 - width24_total ))
      width5_headroom=$(( 320 - width5_total ))
      (( width24_headroom > 0 )) && infos+=("available 2.4 GHz headroom: ${width24_headroom} MHz")
      (( width5_headroom > 0 )) && infos+=("available 5 GHz headroom: ${width5_headroom} MHz")
    fi

    if (( ${#issues[@]} == 0 && ${#infos[@]} == 0 )); then
      continue
    fi

    if [[ "$section_printed" != "true" ]]; then
      print_group_summary_header
      section_printed=true
    fi

    printf '  %s%s%s\n' "$CYAN" "$group_label" "$RESET"
    for member in "${issues[@]}"; do
      printf '  %s! %s%s\n' "$YELLOW" "$member" "$RESET"
    done
    for member in "${infos[@]}"; do
      printf '  %s· %s%s\n' "$GREEN" "$member" "$RESET"
    done
    echo
  done < <(list_site_groups "$site")
}

analyze_band() {
  local band_label=$1 band_key=$2 scan_prefix=$3 mac=$4 ht=$5 channel=$6 tx=$7 min_tx=$8 max_tx=$9
  local txmode=${10} min_rssi=${11} min_rssi_enabled=${12} ib_enabled=${13} dfs_enabled=${14} cac_state=${15} include_roaming=${16}
  local band_has_radio_hint=${17:-false}
  local scan_file="${scan_prefix}.${band_key}"
  local tx_uncapped=$tx rec_tx=$tx rec_rssi=$TX_LO roam_recommended=$ROAM_TARGET
  local current_width peer_count=0
  local width_budget=0 width_over_budget=false width_oversubscribed=false
  local peer_channel peer_width overlap_warn=""
  local _sum_rssi=0 _count_nbr=0 _i=0 _delta _shift_applied _proj
  local shift peer peer_prefix peer_cache rssi_to _j peer_radio_info
  local _warn_lo="" _warn_hi="" _missing_warn=""
  local _nbr_peer=() _nbr_rssi=() _nbr_warn=()
  local _missing_peer=()
  local _overlap_peer=()

  current_width=${ht:-20}

  if grep -qF '===NO_RADIO===' "$scan_file" 2>/dev/null; then
    if [[ "$band_has_radio_hint" != "true" ]]; then
      echo "  ${band_label} GHz: band not active"
      return
    fi
  fi

  print_channel_info "$band_label" "$ht" "$channel" "$tx" "$dfs_enabled"

  for peer in $peers; do
    peer_count=$(( peer_count + 1 ))
  done

  width_budget=320
  [[ "$band_key" == "2g" ]] && width_budget=60
  if [[ "$band_key" == "2g" && $peer_count -gt 3 ]]; then
    width_oversubscribed=true
  fi

  for peer in $peers; do
    peer_radio_info=$(get_radio_info "$site" "$peer")
    IFS='|' read -r \
      peer_ch24 peer_ht24 _peer_tx24 _peer_min_tx24 _peer_max_tx24 _peer_txmode24 _peer_min_rssi24 _peer_min_rssi_en24 \
      peer_ch5 peer_ht5 _peer_tx5 _peer_min_tx5 _peer_max_tx5 _peer_txmode5 _peer_min_rssi5 _peer_min_rssi_en5 \
      _peer_roam_enabled _peer_roam_rssi _peer_ib24 _peer_ib5 _peer_dfs5 <<< "$peer_radio_info"
    if [[ "$band_key" == "2g" ]]; then
      peer_channel=${peer_ch24:-}
      peer_width=${peer_ht24:-20}
    else
      peer_channel=${peer_ch5:-}
      peer_width=${peer_ht5:-20}
    fi
    [[ "$peer_width" =~ ^[0-9]+$ ]] || peer_width=20
    if (( current_width + peer_width > 0 )); then
      width_budget=$(( width_budget - peer_width ))
    fi
    if channels_overlap "$band_key" "$channel" "$current_width" "$peer_channel" "$peer_width"; then
      _overlap_peer+=("$peer")
    fi

    peer_prefix="${_peer_prefixes[$_i]}"
    _i=$(( _i + 1 ))
    peer_cache=$(scan_rssi_cache_path "${peer_prefix}.${band_key}")
    rssi_to=$(get_rssi "$mac" "$peer_cache")
    if [[ -n "$rssi_to" ]]; then
      _nbr_peer+=("$peer")
      _nbr_rssi+=("$rssi_to")
      _sum_rssi=$(( _sum_rssi + rssi_to ))
      _count_nbr=$(( _count_nbr + 1 ))
    else
      _missing_peer+=("$peer")
    fi
  done

  if [[ $_count_nbr -gt 0 ]]; then
    calculate_tx_shift "$_sum_rssi" "$_count_nbr"; shift=$_result
    tx_uncapped=$(( tx + shift ))
    if (( shift == 0 )); then
      rec_tx=$tx
    else
      cap_tx_power "$tx_uncapped" "$min_tx" "$max_tx"; rec_tx=$_result
    fi

    _delta=$(( rec_tx - tx ))
    if (( _delta > 0 )); then
      if (( _delta < HYSTERESIS_UP_DB && rec_tx != max_tx )); then
        rec_tx=$tx
      fi
    elif (( _delta < 0 )); then
      if (( -_delta < HYSTERESIS_DOWN_DB && rec_tx != min_tx )); then
        rec_tx=$tx
      fi
    fi

    calculate_min_rssi_recommendation; rec_rssi=$_result
  fi

  if (( ${#_missing_peer[@]} > 0 )); then
    if (( rec_tx <= tx )); then
      cap_tx_power $(( tx + 1 )) "$min_tx" "$max_tx"; rec_tx=$_result
      tx_uncapped=$rec_tx
    fi
  fi

  if [[ $_count_nbr -gt 0 ]]; then
    _shift_applied=$(( rec_tx - tx ))
    if (( tx_uncapped > max_tx )); then
      for _j in "${!_nbr_peer[@]}"; do
        _proj=$(( _nbr_rssi[_j] + _shift_applied ))
        (( _proj < TX_LO )) && _nbr_warn[_j]="lo"
      done
    elif (( tx_uncapped < min_tx )); then
      for _j in "${!_nbr_peer[@]}"; do
        _proj=$(( _nbr_rssi[_j] + _shift_applied ))
        (( _proj > TX_HI )) && _nbr_warn[_j]="hi"
      done
    fi
  fi

  print_neighbor_header
  for _j in "${!_nbr_peer[@]}"; do
    _starred=""
    [[ "${_nbr_warn[$_j]:-}" != "" ]] && _starred="*"
    print_neighbor_row "${_nbr_peer[$_j]}" "${_nbr_rssi[$_j]}" "$_starred"
  done

  for _j in "${!_nbr_peer[@]}"; do
    case "${_nbr_warn[$_j]:-}" in
      lo) _warn_lo+="${_nbr_peer[$_j]} " ;;
      hi) _warn_hi+="${_nbr_peer[$_j]} " ;;
    esac
  done

  if [[ -n "$_warn_lo" ]]; then
    printf "\n  ${YELLOW}* Coverage gap – signal too weak at: %s${RESET}\n" "${_warn_lo% }"
    printf '  %s  Consider repositioning this AP or adding a neighbor AP.%s\n' "$YELLOW" "$RESET"
  fi
  if [[ -n "$_warn_hi" ]]; then
    printf "\n  ${YELLOW}* Excess overlap – signal too strong at: %s${RESET}\n" "${_warn_hi% }"
    printf '  %s  Consider repositioning or removing this AP.%s\n' "$YELLOW" "$RESET"
  fi
  if (( ${#_missing_peer[@]} > 0 )); then
    _missing_warn="${_missing_peer[*]}"
    printf "\n  ${YELLOW}* Adjacent APs without sighting: %s${RESET}\n" "$_missing_warn"
    printf '  %s  Reduction is blocked until all configured neighbors can see this AP.%s\n' "$YELLOW" "$RESET"
  fi
  if (( current_width > width_budget )); then
    width_over_budget=true
  fi
  if [[ "$width_over_budget" == "true" ]]; then
    if [[ "$band_key" == "5g" ]]; then
      printf "\n  ${YELLOW}* Current 5 GHz width exceeds the local adjacency budget: %d MHz within %d MHz of usable spectrum.${RESET}\n" "$current_width" $(( current_width + (320 - width_budget) ))
      printf '  %s  This adjacency group needs a narrower mix of channel widths to fit into 320 MHz.%s\n' "$YELLOW" "$RESET"
    else
      printf "\n  ${YELLOW}* Current 2.4 GHz width exceeds the local adjacency budget: %d MHz within %d MHz of clean spectrum.${RESET}\n" "$current_width" $(( current_width + (60 - width_budget) ))
      printf '  %s  This adjacency group is wider than the clean 2.4 GHz spectrum allows.%s\n' "$YELLOW" "$RESET"
    fi
  elif [[ "$width_oversubscribed" == "true" ]]; then
    printf "\n  ${YELLOW}* 2.4 GHz is oversubscribed: %d adjacent APs share only the clean channels 1/6/11.${RESET}\n" "$peer_count"
    printf '  %s  Channel width cannot be reduced below 20 MHz; use TX control, AP placement or 5 GHz steering instead.%s\n' "$YELLOW" "$RESET"
  fi
  if (( ${#_overlap_peer[@]} > 0 )); then
    overlap_warn="${_overlap_peer[*]}"
    if [[ "$band_key" == "5g" ]]; then
      printf "\n  ${YELLOW}* Channel overlap with adjacent APs: %s${RESET}\n" "$overlap_warn"
      printf '  %s  Even with the current width, these 5 GHz channels share spectrum and should be separated if possible.%s\n' "$YELLOW" "$RESET"
    else
      printf "\n  ${YELLOW}* Channel overlap with adjacent APs: %s${RESET}\n" "$overlap_warn"
      printf '  %s  In 2.4 GHz, keep adjacent APs on the clean channels 1/6/11 whenever possible.%s\n' "$YELLOW" "$RESET"
    fi
  fi

  if [[ $_count_nbr -gt 0 ]]; then
    print_recommendations_header
    print_rec_channel_layout "$overlap_warn"
    print_rec_tx "$rec_tx" "$txmode" "$tx"
    if [[ "$include_roaming" == "true" ]]; then
      print_rec_roaming "$roam_recommended" "$roam_enabled" "$roam_rssi"
    fi
    print_rec_min_rssi "$rec_rssi" "$min_rssi_enabled" "$min_rssi"
    if is_true "$min_rssi_enabled"; then
      print_rec_interference_blocker "$ib_enabled"
    fi
  else
    echo
    echo "  No neighbor data for ${band_label} GHz"
    if (( ${#_overlap_peer[@]} > 0 )); then
      print_recommendations_header
      print_rec_channel_layout "$overlap_warn"
    fi
    if [[ "$band_key" == "5g" ]]; then
      print_no_neighbor_note "$channel" "$dfs_enabled" "$cac_state"
    fi
  fi
}

