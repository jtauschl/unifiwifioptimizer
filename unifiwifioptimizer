            wlan.get('proxy_arp', ''),
            wlan.get('wlan_band', ''),
            '|'.join(wlan.get('wlan_bands', []) or []),
            wlan.get('mlo_enabled', ''),
            wlan.get('security', ''),
            wlan.get('wpa_mode', ''),
            wlan.get('wpa3_support', ''),
            wlan.get('wpa3_transition', ''),
            wlan.get('pmf_mode', ''),
            wlan.get('hide_ssid', ''),
            wlan.get('l2_isolation', ''),
            wlan.get('sae_anti_clogging', ''),
            wlan.get('sae_sync', ''),
            wlan.get('uapsd_enabled', ''),
            wlan.get('dtim_mode', ''),
            wlan.get('dtim_ng', ''),
            wlan.get('dtim_na', ''),
            wlan.get('dtim_6e', ''),
            wlan.get('group_rekey', ''),
            wlan.get('advertise_device_name_in_beacon', ''),
        ]
        print(sep.join(str(field).replace(sep, ' ') for field in fields))
except Exception:
    sys.exit(1)
PY
  then
    print_api_unavailable_note
    return 1
  fi
}

fetch_site_mgmt_settings() {
  local site=$1
  fetch_api_json "/proxy/network/api/s/${site}/rest/setting/mgmt" "$(site_mgmt_json_path "$site")"
}

count_site_access_points() {
  local site=$1

  fetch_site_devices "$site"
  python3 - "$(site_devices_json_path "$site")" <<'PY'
import json
import sys

devices_path = sys.argv[1]
with open(devices_path, "r", encoding="utf-8") as handle:
    data = json.load(handle).get("data", [])

count = 0
for device in data:
    if device.get("type") == "uap" or device.get("is_access_point") is True:
        count += 1

print(count)
PY
}

build_site_inventory() {
  local site _n _label _ssh_user _ssh_password

  : > "$APS_FILE"
  fetch_controller_sites
  validate_config_sites

  while IFS=$'\t' read -r site _n _label _ssh_user _ssh_password; do
    [[ -z "$site" ]] && continue
    fetch_site_devices "$site"
    fetch_site_wlan_info "$site"

    python3 - "$site" "$NEIGHBORS_FILE" "$WLANS_FILE" "$(site_devices_json_path "$site")" "$(site_wlans_tsv_path "$site")" "$(site_radio_tsv_path "$site")" >> "$APS_FILE" <<'PY'
import json
import sys

site_name, neighbors_path, wlans_path, devices_path, site_wlans_path, radio_path = sys.argv[1:]
required = set()
required_order = []
required_wlans = set()

def pick_radio(items, names, radios):
    for entry in items:
        if entry.get("name") in names:
            return entry
    for entry in items:
        if entry.get("radio") in radios:
            return entry
    return {}

def sanitize_field(value):
    return str(value).replace("\t", " ").replace("\n", " ")

with open(neighbors_path, "r", encoding="utf-8") as handle:
    for line in handle:
        line = line.rstrip("\n")
        if not line:
            continue
        current_site, ap_name, peers = line.split("\t", 2)
        if current_site != site_name:
            continue
        if ap_name not in required:
            required_order.append(ap_name)
        required.add(ap_name)
        for peer in (peer for peer in peers.split(",") if peer):
            if peer not in required:
                required_order.append(peer)
            required.add(peer)

with open(wlans_path, "r", encoding="utf-8") as handle:
    for line in handle:
        line = line.rstrip("\n")
        if not line:
            continue
        current_site, wlan_name, _profile = line.split("\t", 2)
        if current_site != site_name:
            continue
        required_wlans.add(wlan_name)

with open(devices_path, "r", encoding="utf-8") as handle:
    data = json.load(handle).get("data", [])

aps = {}
duplicates = set()
for device in data:
    if device.get("type") != "uap":
        continue
    name = device.get("name", "")
    if name:
        if name in aps:
            duplicates.add(name)
        aps[name] = device

if duplicates:
    sys.stderr.write(
        f'ERROR: Duplicate AP names found in site "{site_name}": {", ".join(sorted(duplicates))}. '
        'AP names must be unique per site for neighbor matching.\n'
    )
    sys.exit(1)

missing = sorted(name for name in required if name not in aps)
if missing:
    sys.stderr.write(
        f'ERROR: The following APs from config.yaml were not found in site "{site_name}": {", ".join(missing)}\n'
    )
    sys.exit(1)

site_wlans = set()
sep = "\x1f"
with open(site_wlans_path, "r", encoding="utf-8") as handle:
    for line in handle:
        line = line.rstrip("\n")
        if not line:
            continue
        fields = line.split(sep)
        if fields:
            site_wlans.add(fields[0])

missing_wlans = sorted(name for name in required_wlans if name not in site_wlans)
if missing_wlans:
    sys.stderr.write(
        f'ERROR: The following WLANs from config.yaml were not found in site "{site_name}": {", ".join(missing_wlans)}\n'
    )
    sys.stderr.write("Check the wlans mapping, then run the script again.\n")
    sys.exit(1)

not_ready = []
radio_rows = []
for ap_name in required_order:
    ap = aps[ap_name]
    model = ap.get("model", "") or ap.get("shortname", "")
    radios = ap.get("radio_table") or []
    r24 = pick_radio(radios, ("ra0", "wifi0"), ("ng", "2g", "2.4", "2.4g"))
    r5 = pick_radio(radios, ("rai0", "wifi1"), ("na", "6e", "5g", "5", "5.8"))
    radio_fields = [
        r24.get("channel", ""),
        r24.get("ht", ""),
        r24.get("tx_power", ""),
        r24.get("min_txpower", ""),
        r24.get("max_txpower", ""),
        r24.get("tx_power_mode", ""),
        r24.get("min_rssi", ""),
        r24.get("min_rssi_enabled", ""),
        r5.get("channel", ""),
        r5.get("ht", ""),
        r5.get("tx_power", ""),
        r5.get("min_txpower", ""),
        r5.get("max_txpower", ""),
        r5.get("tx_power_mode", ""),
        r5.get("min_rssi", ""),
        r5.get("min_rssi_enabled", ""),
        r5.get("assisted_roaming_enabled", ""),
        r5.get("assisted_roaming_rssi", ""),
        r24.get("sens_level_enabled", "") or r24.get("hard_noise_floor_enabled", ""),
        r5.get("sens_level_enabled", "") or r5.get("hard_noise_floor_enabled", ""),
        "true" if r5.get("has_dfs") else "",
    ]
    radio_rows.append(
        f"{sanitize_field(ap_name)}\t{'|'.join(sanitize_field(field) for field in radio_fields)}"
    )

    ip = ap.get("ip") or ap.get("inform_ip") or ""
    if not ip:
        not_ready.append(f"{ap_name} (missing IP)")
        continue
    print("\t".join([site_name, ap_name, ap.get("mac", ""), ip, sanitize_field(model)]))

if not_ready:
    sys.stderr.write(
        f'ERROR: The following APs in site "{site_name}" are not ready for SSH scanning: {", ".join(not_ready)}\n'
    )
    sys.stderr.write(
        "Wait until they are online in UniFi Network, then run the script again.\n"
    )
    sys.exit(1)

with open(radio_path, "w", encoding="utf-8") as handle:
