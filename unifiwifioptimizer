}

# Output-variable convention: arithmetic helpers write their result to _result
# instead of using echo + $(...) to avoid subshell forks. Callers must read
# _result immediately after the call, e.g.: quantize "$val"; result=$_result

get_radio_info() {
  local site=$1 ap=$2
  # Placeholder with the exact number of pipe-separated fields expected by the
  # read below. Used when radio parsing fails so the caller can apply defaults.
  local empty_result='||||||||||||||||||||'
  awk -F '\t' -v ap="$ap" -v empty_result="$empty_result" '
    $1 == ap { print $2; found = 1; exit }
    END { if (!found) print empty_result }
  ' "$(site_radio_tsv_path "$site")" 2>/dev/null
}

channel_center_freq_mhz() {
  local band_key=$1 channel=$2

  [[ "$channel" =~ ^[0-9]+$ ]] || return 1

  case "$band_key" in
    2g) _result=$(( 2407 + channel * 5 )) ;;
    5g) _result=$(( 5000 + channel * 5 )) ;;
    *) return 1 ;;
  esac
}

channel_span_5g() {
  local channel=$1 width=$2

  [[ "$channel" =~ ^[0-9]+$ ]] || return 1
  [[ "$width" =~ ^[0-9]+$ ]] || width=20

  case "$width" in
    20)
      _low=$channel
      _high=$channel
      ;;
    40)
      case "$channel" in
        36|40) _low=36; _high=40 ;;
        44|48) _low=44; _high=48 ;;
        52|56) _low=52; _high=56 ;;
        60|64) _low=60; _high=64 ;;
        100|104) _low=100; _high=104 ;;
        108|112) _low=108; _high=112 ;;
        116|120) _low=116; _high=120 ;;
        124|128) _low=124; _high=128 ;;
        132|136) _low=132; _high=136 ;;
        140|144) _low=140; _high=144 ;;
        149|153) _low=149; _high=153 ;;
        157|161) _low=157; _high=161 ;;
        *) return 1 ;;
      esac
      ;;
    80)
      case "$channel" in
        36|40|44|48) _low=36; _high=48 ;;
        52|56|60|64) _low=52; _high=64 ;;
        100|104|108|112) _low=100; _high=112 ;;
        116|120|124|128) _low=116; _high=128 ;;
        132|136|140|144) _low=132; _high=144 ;;
        149|153|157|161) _low=149; _high=161 ;;
        *) return 1 ;;
      esac
      ;;
    160)
      case "$channel" in
        36|40|44|48|52|56|60|64) _low=36; _high=64 ;;
        100|104|108|112|116|120|124|128) _low=100; _high=128 ;;
        *) return 1 ;;
      esac
      ;;
    *)
      return 1
      ;;
  esac
}

channels_overlap() {
  local band_key=$1 channel_a=$2 width_a=$3 channel_b=$4 width_b=$5
  local freq_a freq_b half_a half_b low_a high_a low_b high_b

  [[ "$width_a" =~ ^[0-9]+$ ]] || width_a=20
  [[ "$width_b" =~ ^[0-9]+$ ]] || width_b=20

  if [[ "$band_key" == "5g" ]]; then
    channel_span_5g "$channel_a" "$width_a" || return 1
    low_a=$_low
    high_a=$_high
    channel_span_5g "$channel_b" "$width_b" || return 1
    low_b=$_low
    high_b=$_high
    (( high_a >= low_b && high_b >= low_a ))
    return
  fi

  channel_center_freq_mhz "$band_key" "$channel_a" || return 1
  freq_a=$_result
  channel_center_freq_mhz "$band_key" "$channel_b" || return 1
  freq_b=$_result

  case "$band_key" in
    2g)
      half_a=$(( width_a / 2 + 2 ))
      half_b=$(( width_b / 2 + 2 ))
      ;;
    *)
      half_a=$(( width_a / 2 ))
      half_b=$(( width_b / 2 ))
      ;;
  esac

  low_a=$(( freq_a - half_a ))
  high_a=$(( freq_a + half_a ))
  low_b=$(( freq_b - half_b ))
  high_b=$(( freq_b + half_b ))

  (( high_a > low_b && high_b > low_a ))
}

cap_tx_power() {
  local tx=$1 min_tx=${2:-$TX_MIN} max_tx=${3:-$TX_MAX}
  (( tx < min_tx )) && tx=$min_tx
  (( tx > max_tx )) && tx=$max_tx
  _result=$tx
}

# ============================================================================
# TX Power Calculation (ALGORITHM.md §5)
# ============================================================================
# Writes SIGNED shift value to _result:
#   positive = increase TX power needed
#   negative = decrease TX power needed
#
# Target: bring the average RSSI @ Neighbor to the center of the TX corridor.
# The derived TX shift uses ceiling rounding, so half steps prefer the next
# higher whole-dBm recommendation instead of rounding down.
# The caller applies cap_tx_power() afterwards.

calculate_tx_shift() {
  local sum_rssi=$1 count_rssi=$2
  local numerator
  local corridor_center=$(( TX_LO + CORRIDOR_WIDTH / 2 ))
  numerator=$(( corridor_center * count_rssi - sum_rssi ))
  if (( numerator >= 0 )); then
    _result=$(( (numerator + count_rssi - 1) / count_rssi ))
  else
    _result=$(( numerator / count_rssi ))
  fi
}

# ============================================================================
# Minimum RSSI Calculation (ALGORITHM.md §6)
# ============================================================================
# Minimum RSSI is always recommended as TX_LO — the lower bound of the TX
# corridor. This is the point where the neighboring cell is clearly stronger
# and a hard disconnect makes sense if Minimum RSSI is enabled at all.

calculate_min_rssi_recommendation() {
  _result=$TX_LO
}

