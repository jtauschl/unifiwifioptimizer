  raw_file="${tmpdir}/$(sanitize_token "$site").wlans.json"

  fetch_api_json "/proxy/network/api/s/${site}/list/wlanconf" "$raw_file"

  if ! python3 - "$raw_file" <<'PY' > "$(site_wlans_tsv_path "$site")" 2>/dev/null
import sys, json

wlans_path = sys.argv[1]

try:
    with open(wlans_path, 'r', encoding='utf-8') as handle:
        d = json.load(handle)
    sep = '\x1f'
    for wlan in d.get('data', []):
