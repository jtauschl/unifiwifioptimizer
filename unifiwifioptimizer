  fi

  echo "    Scanning ${site}/${ap}..."
  if ! ssh_scan_ap "${current_site_ssh_user}@${ip}" "$current_site_ssh_password" > "${scan_prefix}.raw" 2> "$scan_err_file"; then
    : > "${scan_prefix}.raw"
    if [[ -s "$scan_err_file" ]]; then
      printf "    SSH failed: %s\n" "$(tr '\n' ' ' < "$scan_err_file" | sed 's/[[:space:]]\+/ /g; s/^ //; s/ $//')"
    else
      echo "    SSH failed: no details returned"
    fi
  fi

  awk '/^===5GHZ===/ { exit } { print }' "${scan_prefix}.raw" > "${scan_prefix}.2g"
  awk 'found { print } /^===5GHZ===/ { found=1 }' "${scan_prefix}.raw" > "${scan_prefix}.5g"
  build_rssi_cache_file "${scan_prefix}.2g" "$(scan_rssi_cache_path "${scan_prefix}.2g")"
  build_rssi_cache_file "${scan_prefix}.5g" "$(scan_rssi_cache_path "${scan_prefix}.5g")"
done < "$APS_FILE"

echo
echo "  Analyzing recommendations..."
echo

# ============================================================================
# Main: Analysis & Output
# ============================================================================
has_changes=false
has_active_dfs_cac=false

while IFS=$'\t' read -r site n env_label _ssh_user _ssh_password; do
  [[ -z "$site" ]] && continue

  # Compute TX corridor for this site from path loss model
  TX_LO=$(awk "BEGIN { printf \"%.0f\", $ROAM_TARGET - 10*$n*log(100/$OVERLAP_DIST)/log(10) }")
  TX_HI=$(( TX_LO + CORRIDOR_WIDTH ))

  if (( SITE_COUNT > 1 )); then
    print_site_header "$site"
  fi

  print_environment_header
  printf "  %-26s %s\n"              "Environment:"            "$env_label"
  printf "  %-26s %d dBm to %d dBm\n" "Target RSSI @ Neighbor:" "$TX_LO" "$TX_HI"
  printf "  %-26s %d dBm\n"           "Roaming Assistant:"      "$ROAM_TARGET"
  printf "  %-26s %d dBm\n"            "Minimum RSSI:"          "$TX_LO"
  echo

  print_general_checks "$site"

  while IFS=$'\t' read -r current_site ap mac ip model; do
    [[ "$current_site" != "$site" ]] && continue
    mac2g=$(mac_with_offset "$mac" 1)
    mac5g=$(mac_with_offset "$mac" 2)
    peers="$(get_peers "$site" "$ap")"
    scan_prefix=$(ap_scan_prefix "$site" "$ap")
    hw_model=$(get_scan_meta "MODEL_NAME" "${scan_prefix}.raw")
    cac5_state=$(get_scan_meta "DFS_CAC_5G" "${scan_prefix}.raw")
    [[ -n "$hw_model" ]] && model=$hw_model
    [[ "$cac5_state" == "active" ]] && has_active_dfs_cac=true

    # Get current radio info from cached UniFi device data
    # Format: ch24|ht24|tx24|min_tx24|max_tx24|txmode24|min_rssi24|min_rssi_en24|ch5|ht5|tx5|min_tx5|max_tx5|txmode5|min_rssi5|min_rssi_en5|roam_enabled|roam_rssi|ib24|ib5|dfs5
    radio_info=$(get_radio_info "$site" "$ap")
    IFS='|' read -r \
      ch24 cht24 tx24 min_tx24 max_tx24 txmode24 min_rssi24 min_rssi_en24 \
      ch5 cht5 tx5 min_tx5 max_tx5 txmode5 min_rssi5 min_rssi_en5 \
      roam_enabled roam_rssi ib24 ib5 dfs5 <<< "$radio_info"
    has_radio24_api=false; [[ -n "${ch24}${cht24}${tx24}" ]] && has_radio24_api=true
    has_radio5_api=false; [[ -n "${ch5}${cht5}${tx5}" ]] && has_radio5_api=true

    # Warn if critical radio data is missing from the API
    if [[ -z "$tx24" || -z "$tx5" ]]; then
      printf '  %s  ! Warning: incomplete radio data from API — recommendations may use defaults%s\n' "$RED" "$RESET"
    fi

    # Conservative defaults used only when the API does not expose a field.
    # They keep the report readable, but the warning above should be treated
    # as a sign that the recommendation may be less trustworthy.
    ch24=${ch24:-6};      cht24=${cht24:-20}
    tx24=${tx24:-11};     min_tx24=${min_tx24:-$TX_MIN}; max_tx24=${max_tx24:-$TX_MAX}; txmode24=${txmode24:-custom}
    min_rssi24=${min_rssi24:--75};  min_rssi_en24=${min_rssi_en24:-false}
    ch5=${ch5:-100};      cht5=${cht5:-80}
    tx5=${tx5:-20};       min_tx5=${min_tx5:-$TX_MIN}; max_tx5=${max_tx5:-$TX_MAX}; txmode5=${txmode5:-custom}
    min_rssi5=${min_rssi5:--79};    min_rssi_en5=${min_rssi_en5:-false}
    roam_enabled=${roam_enabled:-false}; roam_rssi=${roam_rssi:-}
    ib24=${ib24:-false}; ib5=${ib5:-false}

    print_ap_header "$ap" "$mac" "$model"

    # Pre-compute peer scan prefixes once (reused for both band loops)
    _peer_prefixes=()
    for peer in $peers; do
      _peer_prefixes+=("$(ap_scan_prefix "$site" "$peer")")
    done

    analyze_band "2.4" "2g" "$scan_prefix" "$mac2g" "$cht24" "$ch24" "$tx24" \
      "$min_tx24" "$max_tx24" "$txmode24" "$min_rssi24" "$min_rssi_en24" "$ib24" \
      "" "" "false" "$has_radio24_api"

    echo

    analyze_band "5" "5g" "$scan_prefix" "$mac5g" "$cht5" "$ch5" "$tx5" \
      "$min_tx5" "$max_tx5" "$txmode5" "$min_rssi5" "$min_rssi_en5" "$ib5" \
      "$dfs5" "$cac5_state" "true" "$has_radio5_api"

    echo
  done < "$APS_FILE"

  print_group_issues "$site"
done < "$SITES_FILE"

print_footer "$has_changes" "$has_active_dfs_cac"

exit 0
