    print_general_check_bool "MLO" "$expected_mlo" "$mlo"
    print_general_check_bool "BSS Transition" "$expected_bss_transition" "$bss_transition"
    print_general_check_bool "UAPSD" "$expected_uapsd" "$uapsd"
    print_general_check_dtim_mode "$dtim_mode" "$expected_dtim_mode"
    if [[ "$(normalize_dtim_mode "$expected_dtim_mode")" == "custom" ]]; then
      if wifi_band_includes "$expected_wifi_bands" "2g"; then
        print_general_check_value "DTIM Period 2.4 GHz" "$expected_dtim24" "${dtim24:-n/a}"
      fi
      if wifi_band_includes "$expected_wifi_bands" "5g"; then
        print_general_check_value "DTIM Period 5 GHz" "$expected_dtim5" "${dtim5:-n/a}"
      fi
      if wifi_band_includes "$expected_wifi_bands" "6g"; then
        print_general_check_value "DTIM Period 6 GHz" "$expected_dtim6" "${dtim6:-n/a}"
      fi
    fi
    print_general_check_rekey "Group Rekey Interval" "$expected_group_rekey" "${group_rekey:-0}"
    print_general_check_bool "Show Access Point Name in Beacon" "$expected_ap_name_in_beacon" "$ap_name_in_beacon"
    echo
  done < "$WLANS_FILE"

  if [[ "$matched" != "true" ]]; then
    printf "  ${YELLOW}  ! No WLAN profile mappings configured for site %s${RESET}\n" "$site"
    echo
  fi
}

# print_rec_tx  recommended txmode current
print_rec_tx() {
  local recommended=$1 txmode=$2 current=$3
  local label="Transmit Power"
  local delta=$(( recommended - current ))
  local direction="increase"
  (( delta < 0 )) && direction="reduce"

  if (( recommended == current )); then
    if [[ "$txmode" != "custom" ]]; then
      flag_change
      printf "  ${RED}  ✗ %-${REC_LABEL_WIDTH}s Custom, %d dBm${RESET}\n" "$label" "$current"
      printf "  ${RED}    ! TX Power Mode is \"%s\" - set to Custom first${RESET}\n" "$txmode"
    else
      printf "  ${GREEN}  ✓ %-${REC_LABEL_WIDTH}s Custom, %d dBm${RESET}\n" "$label" "$current"
    fi
  else
    flag_change
    printf "  ${RED}  ✗ %-${REC_LABEL_WIDTH}s Custom, %d dBm (%s by %d dBm)${RESET}\n" \
      "$label" "$recommended" "$direction" "$(( delta < 0 ? -delta : delta ))"
    if [[ "$txmode" != "custom" ]]; then
      printf "  ${RED}    ! TX Power Mode is \"%s\" - set to Custom first${RESET}\n" "$txmode"
    fi
  fi
}

# print_rec_min_rssi  recommended enabled current
print_rec_min_rssi() {
  local recommended=$1 enabled=$2 current=$3
  local label="Minimum RSSI"

  if is_true "$enabled"; then
    flag_change
    printf "  ${RED}  ✗ %-${REC_LABEL_WIDTH}s Disabled${RESET}" "$label"
    if [[ "$current" == "$recommended" ]]; then
      printf " ${GREEN}(if enabled %d dBm)${RESET}\n" "$recommended"
    else
      printf " ${RED}(if enabled %d dBm)${RESET}\n" "$recommended"
    fi
  else
    printf "  ${GREEN}  ✓ %-${REC_LABEL_WIDTH}s Disabled${RESET}\n" "$label"
  fi
}

print_rec_interference_blocker() {
  local enabled=$1
  local label="Interference Blocker"

  if is_true "$enabled"; then
    flag_change
    printf "  ${RED}  ✗ %-${REC_LABEL_WIDTH}s Disabled${RESET}\n" "$label"
  else
    printf "  ${GREEN}  ✓ %-${REC_LABEL_WIDTH}s Disabled${RESET}\n" "$label"
  fi
}

# print_rec_roaming  recommended roam_enabled current_roam_rssi
print_rec_roaming() {
  local recommended=$1 roam_enabled=$2 current_roam_rssi=$3
  local label="Roaming Assistant"

  if ! is_true "$roam_enabled"; then
    flag_change
    printf "  ${RED}  ✗ %-${REC_LABEL_WIDTH}s Enabled, %d dBm${RESET}\n" \
      "$label" "$recommended"
    return
  fi

  if (( recommended != current_roam_rssi )); then
    flag_change
    printf "  ${RED}  ✗ %-${REC_LABEL_WIDTH}s Enabled, %d dBm${RESET}\n" \
      "$label" "$recommended"
  else
    printf "  ${GREEN}  ✓ %-${REC_LABEL_WIDTH}s Enabled, %d dBm${RESET}\n" "$label" "$current_roam_rssi"
  fi
}

