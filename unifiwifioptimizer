# Normalize UniFi-style booleans from multiple controller/API variants.
is_true() {
  case "$1" in
    True|true|TRUE|1|Yes|yes|YES|On|on|ON) return 0 ;;
    *) return 1 ;;
  esac
}

bool_state() {
  is_true "$1" && echo "Enabled" || echo "Disabled"
}

rate_mbps() {
  local kbps=$1 whole rem frac
  whole=$(( kbps / 1000 ))
  rem=$(( kbps % 1000 ))
  if (( rem == 0 )); then
    echo "$whole"
    return
  fi

  frac=$(printf '%03d' "$rem")
  while [[ "$frac" == *0 ]]; do
    frac=${frac%0}
  done
  printf '%d.%s\n' "$whole" "$frac"
}

pmf_state() {
  case "$1" in
    required|Required) echo "Required" ;;
    optional|Optional) echo "Optional" ;;
    disabled|Disabled|"") echo "Disabled" ;;
    *) echo "$1" ;;
  esac
}

security_protocol_state() {
  local security=$1 wpa_mode=$2 wpa3_support=$3 wpa3_transition=$4
  local enterprise=false

  case "$security" in
    wpaeap|wpa-enterprise|enterprise) enterprise=true ;;
  esac

  if [[ "$security" == "open" ]]; then
    echo "Open"
  elif [[ "$enterprise" == "true" ]] && is_true "$wpa3_support" && is_true "$wpa3_transition"; then
    echo "WPA2/WPA3 Enterprise"
  elif [[ "$enterprise" == "true" ]] && is_true "$wpa3_support"; then
    echo "WPA3 Enterprise"
  elif [[ "$enterprise" == "true" ]] && [[ "$wpa_mode" == "wpa2" ]]; then
    echo "WPA2 Enterprise"
  elif is_true "$wpa3_support" && is_true "$wpa3_transition"; then
    echo "WPA2/WPA3"
  elif is_true "$wpa3_support"; then
    echo "WPA3"
  elif [[ "$wpa_mode" == "wpa2" ]]; then
    echo "WPA2"
  else
    echo "${security:-Unknown}"
  fi
}

security_protocol_uses_sae() {
  case "$1" in
    WPA3|WPA2/WPA3) return 0 ;;
    *) return 1 ;;
  esac
}

normalize_wifi_bands() {
  local band=$1 bands=$2
  local source="${bands:-$band}"
  local normalized=""

  case "$source" in
    *2g*|*both*|*all*)
      normalized="2g"
      ;;
  esac

  case "$source" in
    *5g*)
      normalized="${normalized:+${normalized}|}5g"
      ;;
    *both*|*all*)
      [[ "$normalized" != *5g* ]] && normalized="${normalized:+${normalized}|}5g"
      ;;
  esac

  case "$source" in
    *6g*|*6e*|*all*)
      normalized="${normalized:+${normalized}|}6g"
      ;;
  esac

  echo "$normalized"
}

wifi_bands_state() {
  local normalized=$1
  case "$normalized" in
    2g) echo "2.4 GHz only" ;;
    5g) echo "5 GHz only" ;;
    6g) echo "6 GHz only" ;;
    2g\|5g) echo "2.4 GHz, 5 GHz" ;;
    2g\|6g) echo "2.4 GHz, 6 GHz" ;;
    5g\|6g) echo "5 GHz, 6 GHz" ;;
    2g\|5g\|6g) echo "2.4 GHz, 5 GHz, 6 GHz" ;;
    "") echo "n/a" ;;
    *) echo "$normalized" ;;
  esac
}

wifi_band_includes() {
  local normalized=$1 target=$2
  case "|$normalized|" in
    *"|$target|"*) return 0 ;;
    *) return 1 ;;
  esac
}

security_protocol_allowed() {
  local allowed=$1 current=$2 item
  IFS='|' read -r -a allowed_items <<< "$allowed"
  for item in "${allowed_items[@]}"; do
    [[ "$item" == "$current" ]] && return 0
  done
  return 1
}

security_protocol_expected_state() {
  local allowed=$1
  echo "${allowed//|/, }"
}

rekey_state() {
  local seconds=$1
  if [[ -z "$seconds" || "$seconds" == "0" || "$seconds" == "disabled" || "$seconds" == "Disabled" ]]; then
    echo "Disabled"
  else
    echo "${seconds} s"
  fi
}

normalize_rekey() {
  local value=$1
  if [[ -z "$value" || "$value" == "0" || "$value" == "disabled" || "$value" == "Disabled" ]]; then
    echo "0"
  else
    echo "$value"
  fi
}

normalize_minrate_mode() {
  local value
  value=$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]')
  case "$value" in
    auto|"") echo "auto" ;;
    manual) echo "manual" ;;
    *) echo "$1" ;;
  esac
}

minrate_mode_state() {
  case "$(normalize_minrate_mode "$1")" in
