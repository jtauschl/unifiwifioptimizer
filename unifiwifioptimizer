import re
import sys

source_file, cache_file = sys.argv[1:]
with open(source_file, "r", encoding="utf-8", errors="ignore") as handle:
    text = handle.read().split("===META===", 1)[0]

mac_re = re.compile(r"^[0-9a-f]{2}(?::[0-9a-f]{2}){5}$")

def write_rows(rows):
    with open(cache_file, "w", encoding="utf-8") as handle:
        for mac, rssi in sorted(rows.items()):
            handle.write(f"{mac}\t{rssi}\n")

best = {}
current_mac = ""
for line in text.splitlines():
    fields = line.split()
    if len(fields) >= 2 and fields[0] == "BSS":
        current_mac = fields[1].split("(", 1)[0].lower()
        continue
    if len(fields) >= 2 and fields[0] == "signal:" and current_mac:
        try:
            rssi = int(float(fields[1]))
        except ValueError:
            current_mac = ""
            continue
        if mac_re.match(current_mac) and -100 < rssi < 0:
            if current_mac not in best or rssi > best[current_mac]:
                best[current_mac] = rssi
        current_mac = ""

write_rows(best)
