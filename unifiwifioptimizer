mac_with_offset() {
  local mac=$1 offset=$2 hex dec new
  hex=${mac//:/}
  dec=$((16#$hex))
  new=$(((dec + offset) & 0xFFFFFFFFFFFF))
  hex=$(printf '%012x' "$new")
  printf '%s:%s:%s:%s:%s:%s\n' \
    "${hex:0:2}" "${hex:2:2}" "${hex:4:2}" \
    "${hex:6:2}" "${hex:8:2}" "${hex:10:2}"
}

