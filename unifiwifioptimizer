#!/usr/bin/env bash

#
# UniFi WiFi Optimizer
#
# Determines TX Power and Roaming Assistant recommendations, plus
# Minimum RSSI guidance, based on neighbor RSSI measurements
# from neighbor APs.
#
# Algorithm: See docs/ALGORITHM.md
# Config:    See config.yaml and profiles.yaml
#
# Usage:
#   ./unifiwifioptimizer
#   ./unifiwifioptimizer --sites
#   ./unifiwifioptimizer --site <siteid>
#   ./unifiwifioptimizer --config <siteid>
#

set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
CONFIG_FILE="${SCRIPT_DIR}/config.yaml"
PROFILES_FILE="${SCRIPT_DIR}/profiles.yaml"
WLAN_FIELD_SEP=$'\037'

# Default optimizer parameters
#
# Design basis (Cisco VoWLAN guidelines):
#   CELL_EDGE      = -67 dBm   minimum RSSI at cell edge for voice
#   CELL_OVERLAP   =  20 %     cell area overlap between neighbor APs
#
# Derived constants:
#   ROAM_TARGET    = -67 dBm   roaming threshold at the overlap point
#   OVERLAP_DIST   =  60 %     distance ratio corresponding to ~20% area overlap
#   CORRIDOR_WIDTH =   6 dB    symmetric tolerance around corridor center
#
# TX corridor derivation (per site, using path loss exponent n):
#     ΔdB   = 10 · n · log10(100 / OVERLAP_DIST)
#     TX_LO = ROAM_TARGET − ΔdB
#     TX_HI = TX_LO + CORRIDOR_WIDTH
#
#   n is site-specific, set via config.yaml (sites.<site>.environment).
ROAM_TARGET=-67   # RSSI at the overlap point (dBm) — Cisco VoWLAN: -67 dBm cell edge
OVERLAP_DIST=60   # overlap point as % of AP-to-AP distance (~20% area overlap)
CORRIDOR_WIDTH=6  # corridor width in dB
#
# Path loss exponent n: set environment per site in config.yaml (default: Residential)
# Values are derived from ITU-R P.1238 Table 2, using n where ITU expresses
# the same coefficient as N = 10*n.
#   Preset        n     ΔdB    TX_LO   ITU-R P.1238 category
#   Open          2.2   4.88   −72     Commercial (large open spaces, retail)
#   Residential   2.8   6.21   −73     Residential (default)
#   Office        3.0   6.65   −74     Office
#   Obstructed    4.0   8.87   −76     Obstructed (concrete, brick, multi-wall)
#   <number>      x     —      —       Custom value (e.g. 3.5 → TX_LO ≈ −75)
#
# Conservative fallback limits if the controller does not expose per-radio
# TX min/max values. Small TX changes are suppressed by asymmetric hysteresis:
# prefer slight extra TX over creating a coverage gap.
TX_MIN=6
TX_MAX=23
HYSTERESIS_UP_DB=1
HYSTERESIS_DOWN_DB=2
SCAN_ATTEMPTS=2

# Output colors and label widths used by the terminal report
RED=$'\e[31m'
YELLOW=$'\e[33m'
GREEN=$'\e[32m'
CYAN=$'\e[36m'
RESET=$'\e[0m'
GENERAL_LABEL_WIDTH=32
REC_LABEL_WIDTH=24

# Create and clean up temp dir for controller snapshots, parsed TSV data,
# and AP scan output collected during this run.
tmpdir=$(mktemp -d)
trap '[[ -n "$tmpdir" && -d "$tmpdir" ]] && rm -rf "$tmpdir"' EXIT

# Temporary files used throughout the run
ENV_FILE="${tmpdir}/controller.env"
SITES_FILE="${tmpdir}/sites.tsv"
WLANS_FILE="${tmpdir}/wlans.tsv"
NEIGHBORS_FILE="${tmpdir}/neighbors.tsv"
PROFILES_TSV="${tmpdir}/profiles.tsv"
APS_FILE="${tmpdir}/aps.tsv"
CONTROLLER_SITES_FILE="${tmpdir}/controller-sites.txt"

# ============================================================================
# Helper Functions
# ============================================================================

print_usage() {
  cat <<'EOF'
Usage:
  ./unifiwifioptimizer
  ./unifiwifioptimizer --sites
  ./unifiwifioptimizer --site <siteid>
  ./unifiwifioptimizer --config <siteid>
EOF
}

require_config_file() {
  if [[ ! -f "$CONFIG_FILE" ]]; then
    echo "ERROR: Config file not found: $CONFIG_FILE" >&2
    exit 1
  fi
}

require_profiles_file() {
  if [[ ! -f "$PROFILES_FILE" ]]; then
    echo "ERROR: Profiles file not found: $PROFILES_FILE" >&2
    exit 1
  fi
}

print_api_unavailable_note() {
  printf 'NOTE: API (%s) is not available.\n' "$UNIFI_URL" >&2
}

fetch_api_json() {
  local endpoint=$1 output_path=$2 timeout=${3:-15}

  if ! curl -k -s -f --max-time "$timeout" \
    -H "X-API-KEY: ${UNIFI_API_KEY}" \
    -H "Accept: application/json" \
    "${UNIFI_URL}${endpoint}" \
    2>/dev/null > "$output_path"; then
    print_api_unavailable_note
    return 1
  fi

  if [[ ! -s "$output_path" ]]; then
    print_api_unavailable_note
    return 1
  fi
}

load_controller_config() {
  ruby - "$CONFIG_FILE" "$tmpdir" <<'RUBY'
require "yaml"
require "shellwords"

config_path, out_dir = ARGV
config = YAML.load_file(config_path) || {}
controller = config["controller"] || {}

abort("ERROR: config.yaml is missing controller.url") if controller["url"].to_s.empty?
abort("ERROR: config.yaml is missing controller.api_key") if controller["api_key"].to_s.empty?

env_lines = []
env_lines << "UNIFI_URL=#{Shellwords.escape(controller['url'].to_s)}"
env_lines << "UNIFI_API_KEY=#{Shellwords.escape(controller['api_key'].to_s)}"
File.write(File.join(out_dir, "controller.env"), env_lines.join("\n") + "\n")
RUBY

  # shellcheck source=/dev/null
  . "$ENV_FILE"
}

check_dependencies() {
  local missing=()
  local cmd

  for cmd in awk curl python3 ruby ssh; do
    if ! command -v "$cmd" >/dev/null 2>&1; then
      missing+=("$cmd")
    fi
  done

  if awk -F '\t' 'NF >= 5 && $5 != "" { found=1 } END { exit found ? 0 : 1 }' "$SITES_FILE"; then
    if ! command -v sshpass >/dev/null 2>&1; then
      missing+=("sshpass")
    fi
  fi

  if (( ${#missing[@]} > 0 )); then
    printf 'ERROR: Missing required command(s): %s\n' "${missing[*]}" >&2
    if [[ " ${missing[*]} " == *" sshpass "* ]]; then
      printf '%s\n' "Omit sites.<site>.ssh.password in config.yaml to use SSH key authentication instead." >&2
    fi
    exit 1
  fi
}

load_yaml_config() {
  ruby - "$CONFIG_FILE" "$PROFILES_FILE" "$tmpdir" <<'RUBY'
require "yaml"
require "shellwords"

config_path, profiles_path, out_dir = ARGV
config = YAML.load_file(config_path) || {}
profiles_doc = YAML.load_file(profiles_path) || {}

controller = config["controller"] || {}
sites = config["sites"] || {}
profiles = profiles_doc["profiles"] || {}
abort("ERROR: config.yaml is missing controller.url") if controller["url"].to_s.empty?
abort("ERROR: config.yaml is missing controller.api_key") if controller["api_key"].to_s.empty?
abort("ERROR: config.yaml must define at least one site under sites") if sites.empty?
abort("ERROR: profiles.yaml must define at least one profile") if profiles.empty?

env_lines = []
env_lines << "UNIFI_URL=#{Shellwords.escape(controller['url'].to_s)}"
env_lines << "UNIFI_API_KEY=#{Shellwords.escape(controller['api_key'].to_s)}"
File.write(File.join(out_dir, "controller.env"), env_lines.join("\n") + "\n")

File.write(File.join(out_dir, "sites.tsv"), "")
File.write(File.join(out_dir, "wlans.tsv"), "")
File.write(File.join(out_dir, "neighbors.tsv"), "")
File.write(File.join(out_dir, "profiles.tsv"), "")

profile_fields = %w[
  wifi_bands
  mlo
  fast_roaming
  minrate_mode
  minrate_24_kbps
  minrate_5_kbps
  multicast_broadcast_blocker
  multicast_to_unicast
  proxy_arp
  security_protocols
  pmf
  hide_wifi_name
  client_device_isolation
  sae_anti_clogging
  sae_sync_time
  bss_transition
  uapsd
  dtim_mode
  dtim_24
  dtim_5
  dtim_6
  group_rekey
  ap_name_in_beacon
]

profiles.each do |name, values|
  wifi_bands = Array(values["wifi_bands"]).map(&:to_s)
  minrate_mode = values["minrate_mode"].to_s
  dtim_mode = values["dtim_mode"].to_s
  abort("ERROR: profile #{name}: minrate_mode must be auto or manual") unless %w[auto manual].include?(minrate_mode)
  abort("ERROR: profile #{name}: dtim_mode must be default or custom") unless %w[default custom].include?(dtim_mode)
  optional_fields = []
  optional_fields << "mlo" unless wifi_bands.include?("6g")
  if minrate_mode != "manual"
    optional_fields << "minrate_24_kbps"
    optional_fields << "minrate_5_kbps"
  else
    optional_fields << "minrate_24_kbps" unless wifi_bands.include?("2g")
    optional_fields << "minrate_5_kbps" unless wifi_bands.include?("5g")
  end
  if dtim_mode != "custom"
    optional_fields << "dtim_24"
    optional_fields << "dtim_5"
    optional_fields << "dtim_6"
  else
    optional_fields << "dtim_24" unless wifi_bands.include?("2g")
    optional_fields << "dtim_5" unless wifi_bands.include?("5g")
    optional_fields << "dtim_6" unless wifi_bands.include?("6g")
  end

  missing = profile_fields.reject do |field|
    values.key?(field) || optional_fields.include?(field)
  end
  abort("ERROR: profile #{name} is missing keys: #{missing.join(', ')}") unless missing.empty?
  defaults = {
    "mlo" => false,
    "minrate_mode" => "manual",
    "minrate_24_kbps" => 0,
    "minrate_5_kbps" => 0,
    "dtim_mode" => "custom",
    "dtim_24" => 0,
    "dtim_5" => 0,
    "dtim_6" => 0,
  }
  row = [name] + profile_fields.map do |field|
    value = values.key?(field) ? values[field] : defaults[field]
    value.is_a?(Array) ? value.join("|") : value
  end
  File.open(File.join(out_dir, "profiles.tsv"), "a") do |f|
    f.puts(row.map(&:to_s).join("\t"))
  end
end

sites.each do |site_name, site_cfg|
  site_ssh = site_cfg["ssh"] || {}
  ssh_user = site_ssh["user"].to_s
  ssh_password = (site_ssh["password"] || "").to_s
  neighbors = site_cfg["neighbors"] || {}
  wlans = site_cfg["wlans"] || {}

  abort("ERROR: site #{site_name} is missing ssh.user") if ssh_user.empty?
  abort("ERROR: site #{site_name} must define neighbors") if neighbors.empty?

  rf_presets = {
    "open"        => [2.2, "Open"],
    "residential" => [2.8, "Residential"],
    "office"      => [3.0, "Office"],
    "obstructed"  => [4.0, "Obstructed"],
  }
  rf_env = (site_cfg["environment"] || "Residential").to_s
  rf_env_key = rf_env.downcase
  if rf_presets.key?(rf_env_key)
    n, env_label = rf_presets[rf_env_key]
  else
    n = rf_env.to_f
    abort("ERROR: site #{site_name}: environment must be Open, Residential, Office, Obstructed, or a positive number (got: #{rf_env})") unless n > 0
    env_label = "Custom (n=#{rf_env})"
  end

  File.open(File.join(out_dir, "sites.tsv"), "a") do |f|
    f.puts([site_name, n, env_label, ssh_user, ssh_password].join("\t"))
  end

  wlans.each do |wlan_name, profile_name|
    abort("ERROR: WLAN #{wlan_name} in site #{site_name} references unknown profile #{profile_name}") unless profiles.key?(profile_name)
    File.open(File.join(out_dir, "wlans.tsv"), "a") do |f|
      f.puts([site_name, wlan_name, profile_name].join("\t"))
    end
  end

  neighbors.each do |ap_name, peers|
    peer_list = Array(peers).map(&:to_s)
    abort("ERROR: neighbors for #{ap_name} in site #{site_name} must list at least one peer") if peer_list.empty?
    File.open(File.join(out_dir, "neighbors.tsv"), "a") do |f|
      f.puts([site_name, ap_name, peer_list.join(",")].join("\t"))
    end
  end
end
RUBY

  # shellcheck source=/dev/null
  . "$ENV_FILE"
}

sanitize_token() {
  printf '%s' "$1" | tr -c 'A-Za-z0-9_.-' '_'
}

site_devices_json_path() {
  local site=$1
  printf "%s/%s.devices.json\n" "$tmpdir" "$(sanitize_token "$site")"
}

site_wlans_tsv_path() {
  local site=$1
  printf "%s/%s.wlans.tsv\n" "$tmpdir" "$(sanitize_token "$site")"
}

site_mgmt_json_path() {
  local site=$1
  printf "%s/%s.mgmt.json\n" "$tmpdir" "$(sanitize_token "$site")"
}

site_radio_tsv_path() {
  local site=$1
  printf "%s/%s.radios.tsv\n" "$tmpdir" "$(sanitize_token "$site")"
}

site_ssh_credentials() {
  local site=$1 creds
  creds=$(awk -F '\t' -v site="$site" '$1 == site { print $4 "\t" $5; exit }' "$SITES_FILE")
  if [[ -z "$creds" ]]; then
    printf 'ERROR: Could not load SSH credentials for site "%s"\n' "$site" >&2
    return 1
  fi
  printf '%s\n' "$creds"
}

fetch_controller_sites() {
  local raw_file="${tmpdir}/controller-sites.json"

  fetch_api_json "/proxy/network/api/self/sites" "$raw_file" 10

  if ! python3 - "$raw_file" <<'PY' > "$CONTROLLER_SITES_FILE" 2>/dev/null
import sys, json

sites_path = sys.argv[1]

try:
    with open(sites_path, 'r', encoding='utf-8') as handle:
        d = json.load(handle)
    for site in d.get('data', []):
        fields = [
            site.get('name', ''),
            site.get('desc', '') or site.get('name', ''),
            site.get('attr_hidden_id', '') or site.get('name', ''),
            site.get('device_count', ''),
        ]
        print('\t'.join(str(field).replace('\t', ' ') for field in fields))
except Exception:
    sys.exit(1)
PY
  then
    print_api_unavailable_note
    return 1
  fi
}

validate_config_sites() {
  local site _n _label _ssh_user _ssh_password
  while IFS=$'\t' read -r site _n _label _ssh_user _ssh_password; do
    [[ -z "$site" ]] && continue
    if ! awk -F '\t' -v site="$site" '$1 == site { found=1 } END { exit found ? 0 : 1 }' "$CONTROLLER_SITES_FILE"; then
      printf 'ERROR: Site "%s" from config.yaml was not found in the UniFi controller\n' "$site" >&2
      exit 1
    fi
  done < "$SITES_FILE"
}

resolve_site_id() {
  local site_id=$1
  local match

  match=$(awk -F '\t' -v site_id="$site_id" '$1 == site_id { print; exit }' "$CONTROLLER_SITES_FILE")
  if [[ -n "$match" ]]; then
    printf '%s\n' "$match"
    return
  fi

  printf 'ERROR: Site ID "%s" was not found. Use --sites to list available site IDs.\n' "$site_id" >&2
  exit 1
}

fetch_site_devices() {
  local site=$1
  fetch_api_json "/proxy/network/api/s/${site}/stat/device" "$(site_devices_json_path "$site")"
}

