# Output-variable convention: arithmetic helpers write their result to _result
# instead of using echo + $(...) to avoid subshell forks. Callers must read
# _result immediately after the call, e.g.: quantize "$val"; result=$_result

# Round to nearest QUANTIZATION step, biased towards higher TX power:
#   positive shift: ceiling (round up → more TX increase)
#   negative shift: floor-towards-zero (round towards 0 → less TX reduction)
quantize() {
  local val=$1
  local q=${QUANTIZATION:-3}
  if (( val >= 0 )); then
    _result=$(( (val + q - 1) / q * q ))
  else
    _result=$(( -((-val) / q * q) ))
  fi
}

get_radio_info() {
  local site=$1 ap=$2
  # Placeholder with the exact number of pipe-separated fields expected by the
  # read below. Used when radio parsing fails so the caller can apply defaults.
  local empty_result='|||||||||||||||||||'

  # Extract 2.4/5 GHz radio values via python3, accepting both
  # older ra0/rai0 and newer wifi0/wifi1 naming.
  local result
  result=$(python3 - "$ap" "$(site_devices_json_path "$site")" "$empty_result" <<'PY'
import sys, json

def pick_radio(items, names, radios):
    for entry in items:
        if entry.get('name') in names:
            return entry
    for entry in items:
        if entry.get('radio') in radios:
            return entry
    return {}

ap_name, devices_path, empty_result = sys.argv[1:]

try:
    with open(devices_path, 'r', encoding='utf-8') as handle:
        data = json.load(handle).get('data', [])
    device = next((item for item in data if item.get('type') == 'uap' and item.get('name') == ap_name), None)
    if device is None:
        raise RuntimeError(f'AP not found: {ap_name}')
    radios = device['radio_table']
    r24 = pick_radio(radios, ('ra0', 'wifi0'), ('ng', '2g', '2.4', '2.4g'))
    r5  = pick_radio(radios, ('rai0', 'wifi1'), ('na', '6e', '5g', '5', '5.8'))
    ch24      = r24.get('channel', '')
    ht24      = r24.get('ht', '')
    tx24      = r24.get('tx_power', '')
    min_tx24  = r24.get('min_txpower', '')
    max_tx24  = r24.get('max_txpower', '')
    rssi24    = r24.get('min_rssi', '')
    min_rssi_en24 = r24.get('min_rssi_enabled', '')
    ib24          = r24.get('sens_level_enabled', '') or r24.get('hard_noise_floor_enabled', '')
    txmode24      = r24.get('tx_power_mode', '')
    ch5           = r5.get('channel', '')
    ht5           = r5.get('ht', '')
    tx5           = r5.get('tx_power', '')
    min_tx5       = r5.get('min_txpower', '')
    max_tx5       = r5.get('max_txpower', '')
    rssi5         = r5.get('min_rssi', '')
    min_rssi_en5  = r5.get('min_rssi_enabled', '')
    ib5           = r5.get('sens_level_enabled', '') or r5.get('hard_noise_floor_enabled', '')
    txmode5       = r5.get('tx_power_mode', '')
    roam_en   = r5.get('assisted_roaming_enabled', '')
    roam_rssi = r5.get('assisted_roaming_rssi', '')
    print(f'{ch24}|{ht24}|{tx24}|{min_tx24}|{max_tx24}|{txmode24}|{rssi24}|{min_rssi_en24}|{ch5}|{ht5}|{tx5}|{min_tx5}|{max_tx5}|{txmode5}|{rssi5}|{min_rssi_en5}|{roam_en}|{roam_rssi}|{ib24}|{ib5}')
except Exception as e:
    import sys as _sys
    print(f'WARNING: get_radio_info failed for AP "{ap_name}": {e}', file=_sys.stderr)
    print(empty_result)
PY
)

  echo "$result"
}

cap_tx_power() {
  local tx=$1 min_tx=${2:-$TX_MIN} max_tx=${3:-$TX_MAX}
  (( tx < min_tx )) && tx=$min_tx
  (( tx > max_tx )) && tx=$max_tx
  _result=$tx
}

# ============================================================================
# TX Power Calculation (ALGORITHM.md §5)
# ============================================================================
# Writes SIGNED shift value to _result:
#   positive = increase TX power needed
#   negative = decrease TX power needed
#
# Target: bring the average RSSI @ Neighbor to the center of the TX corridor.
# The caller applies quantize() and cap_tx_power() afterwards.

calculate_tx_shift() {
  local avg=$1
  local corridor_center=$(( TX_LO + CORRIDOR_WIDTH / 2 ))
  _result=$(( corridor_center - avg ))
}

# ============================================================================
# Minimum RSSI Calculation (ALGORITHM.md §6)
# ============================================================================
# Minimum RSSI is always recommended as TX_LO — the lower bound of the TX
# corridor. This is the point where the neighboring cell is clearly stronger
# and a hard disconnect makes sense if Minimum RSSI is enabled at all.

calculate_min_rssi_recommendation() {
  _result=$TX_LO
}

