    if value[0] in "-?":
        safe = False
    if any(ch in disallowed for ch in value):
        safe = False
    if safe:
        return value
    escaped = value.replace("\\", "\\\\").replace('"', '\\"')
    return f'"{escaped}"'

wlans = []
sep = "\x1f"

with open(wlans_path, "r", encoding="utf-8") as handle:
