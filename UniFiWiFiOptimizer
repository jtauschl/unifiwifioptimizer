}

print_general_checks() {
  local site=$1
  local matched=false
  local wlan_name profile_name actual_row profile_row
  local enabled bss_transition fast_roaming
  local minrate_mode dtim_mode
  local minrate24_en minrate24 minrate5_en minrate5
  local bc_filter mcast_enhance proxy_arp
  local wlan_band wlan_bands mlo security wpa_mode wpa3_support wpa3_transition pmf
  local hide_ssid l2_isolation sae_anti_clogging sae_sync uapsd
  local dtim24 dtim5 dtim6 group_rekey ap_name_in_beacon
  local profile expected_wifi_bands expected_mlo expected_fast_roaming expected_minrate_mode expected_minrate24 expected_minrate5
  local expected_bc_filter expected_mcast_enhance expected_proxy_arp
  local expected_security_protocols expected_pmf expected_hide_wifi_name
  local expected_client_device_isolation expected_sae_anti_clogging expected_sae_sync_time
  local expected_bss_transition expected_uapsd expected_dtim_mode expected_dtim24 expected_dtim5 expected_dtim6
  local expected_group_rekey expected_ap_name_in_beacon
  local actual_wifi_bands actual_security_protocol actual_pmf

  if [[ ! -s "$(site_wlans_tsv_path "$site")" ]]; then
    printf "  ${YELLOW}  ! Could not read WLAN settings from UniFi API for site %s${RESET}\n" "$site"
    echo
    return
  fi

  while IFS=$'\t' read -r current_site wlan_name profile_name; do
    [[ "$current_site" != "$site" ]] && continue
    matched=true
    print_wlan_header "$wlan_name" "$profile_name"

    actual_row=$(get_site_wlan_row "$site" "$wlan_name")
    if [[ -z "$actual_row" ]]; then
      printf 'ERROR: WLAN "%s" from config.yaml was not found in site "%s". Check the wlans mapping, then run the script again.\n' "$wlan_name" "$site" >&2
      exit 1
    fi

    IFS="$WLAN_FIELD_SEP" read -r \
      _name enabled bss_transition fast_roaming \
      minrate_mode \
      minrate24_en minrate24 minrate5_en minrate5 \
      bc_filter mcast_enhance proxy_arp \
      wlan_band wlan_bands mlo security wpa_mode wpa3_support wpa3_transition pmf \
      hide_ssid l2_isolation sae_anti_clogging sae_sync uapsd \
      dtim_mode \
      dtim24 dtim5 dtim6 group_rekey ap_name_in_beacon <<< "$actual_row"

    if ! is_true "$enabled"; then
      print_general_check_missing "WLAN Enabled" "Enabled"
      echo
      continue
    fi

    profile_row=$(get_profile_row "$profile_name")
    if [[ -z "$profile_row" ]]; then
      print_general_check_missing "Profile" "$profile_name"
      echo
      continue
    fi

    IFS=$'\t' read -r \
      profile expected_wifi_bands expected_mlo expected_fast_roaming expected_minrate_mode expected_minrate24 expected_minrate5 \
      expected_bc_filter expected_mcast_enhance expected_proxy_arp \
      expected_security_protocols expected_pmf expected_hide_wifi_name \
      expected_client_device_isolation expected_sae_anti_clogging expected_sae_sync_time \
      expected_bss_transition expected_uapsd expected_dtim_mode expected_dtim24 expected_dtim5 expected_dtim6 \
      expected_group_rekey expected_ap_name_in_beacon <<< "$profile_row"

    actual_wifi_bands=$(normalize_wifi_bands "$wlan_band" "$wlan_bands")
    actual_security_protocol=$(security_protocol_state "$security" "$wpa_mode" "$wpa3_support" "$wpa3_transition")
    actual_pmf=$(pmf_state "$pmf")

    print_general_group_header "  Radio Setup:"
    print_general_check_bands "WiFi Band" "$expected_wifi_bands" "$actual_wifi_bands"
    if wifi_band_includes "$expected_wifi_bands" "6g"; then
      print_general_check_bool "MLO" "$expected_mlo" "$mlo"
    fi

    echo
    print_general_group_header "  Roaming Assistance:"
    print_general_check_bool "Fast Roaming" "$expected_fast_roaming" "$fast_roaming"

    echo
    print_general_group_header "  Hi-Capacity Tuning:"
    print_general_check_minrate_mode "$minrate_mode" "$expected_minrate_mode"
    if [[ "$(normalize_minrate_mode "$expected_minrate_mode")" == "manual" ]]; then
      if wifi_band_includes "$expected_wifi_bands" "2g"; then
        print_general_check_rate "Minimum Data Rate 2.4 GHz" "$expected_minrate24" "$minrate24_en" "$minrate24"
      fi
      if wifi_band_includes "$expected_wifi_bands" "5g"; then
        print_general_check_rate "Minimum Data Rate 5 GHz" "$expected_minrate5" "$minrate5_en" "$minrate5"
      fi
    fi
    print_general_check_bool "Multicast and Broadcast Blocker" "$expected_bc_filter" "$bc_filter"
    print_general_check_bool "Multicast to Unicast" "$expected_mcast_enhance" "$mcast_enhance"
    print_general_check_bool "Proxy ARP" "$expected_proxy_arp" "$proxy_arp"

    echo
    print_general_group_header "  Security:"
    print_general_check_protocol "Security Protocol" "$expected_security_protocols" "$actual_security_protocol"
    print_general_check_value "PMF" "$expected_pmf" "$actual_pmf"
    print_general_check_bool "Hide WiFi Name" "$expected_hide_wifi_name" "$hide_ssid"
    print_general_check_bool "Client Device Isolation" "$expected_client_device_isolation" "$l2_isolation"
    if security_protocol_uses_sae "$actual_security_protocol"; then
      print_general_check_value "SAE Anti-clogging" "$expected_sae_anti_clogging" "${sae_anti_clogging:-n/a}"
      print_general_check_value "SAE Sync Time" "$expected_sae_sync_time" "${sae_sync:-n/a}"
    fi

    echo
    print_general_group_header "  Behaviour Controls:"
    print_general_check_bool "BSS Transition" "$expected_bss_transition" "$bss_transition"
    print_general_check_bool "UAPSD" "$expected_uapsd" "$uapsd"
    print_general_check_dtim_mode "$dtim_mode" "$expected_dtim_mode"
    if [[ "$(normalize_dtim_mode "$expected_dtim_mode")" == "custom" ]]; then
      if wifi_band_includes "$expected_wifi_bands" "2g"; then
        print_general_check_value "DTIM Period 2.4 GHz" "$expected_dtim24" "${dtim24:-n/a}"
      fi
      if wifi_band_includes "$expected_wifi_bands" "5g"; then
        print_general_check_value "DTIM Period 5 GHz" "$expected_dtim5" "${dtim5:-n/a}"
      fi
      if wifi_band_includes "$expected_wifi_bands" "6g"; then
        print_general_check_value "DTIM Period 6 GHz" "$expected_dtim6" "${dtim6:-n/a}"
      fi
    fi
    print_general_check_rekey "Group Rekey Interval" "$expected_group_rekey" "${group_rekey:-0}"
    print_general_check_bool "Show Access Point Name in Beacon" "$expected_ap_name_in_beacon" "$ap_name_in_beacon"
    echo
  done < "$WLANS_FILE"

  if [[ "$matched" != "true" ]]; then
    printf "  ${YELLOW}  ! No WLAN profile mappings configured for site %s${RESET}\n" "$site"
    echo
  fi
}

# print_rec_tx  recommended txmode current
print_rec_tx() {
  local recommended=$1 txmode=$2 current=$3
  local label="Transmit Power"
  local delta=$(( recommended - current ))
  local direction="increase"
  (( delta < 0 )) && direction="reduce"

  if (( recommended == current )); then
    if [[ "$txmode" != "custom" ]]; then
      flag_change
      printf "  ${RED}  ✗ %-${REC_LABEL_WIDTH}s Custom, %d dBm${RESET}\n" "$label" "$current"
      printf "  ${RED}    ! TX Power Mode is \"%s\" - set to Custom first${RESET}\n" "$txmode"
    else
      printf "  ${GREEN}  ✓ %-${REC_LABEL_WIDTH}s Custom, %d dBm${RESET}\n" "$label" "$current"
    fi
  else
    flag_change
    printf "  ${RED}  ✗ %-${REC_LABEL_WIDTH}s Custom, %d dBm (%s by %d dBm)${RESET}\n" \
      "$label" "$recommended" "$direction" "$(( delta < 0 ? -delta : delta ))"
    if [[ "$txmode" != "custom" ]]; then
      printf "  ${RED}    ! TX Power Mode is \"%s\" - set to Custom first${RESET}\n" "$txmode"
    fi
  fi
}

# print_rec_min_rssi  recommended enabled current
print_rec_min_rssi() {
  local recommended=$1 enabled=$2 current=$3
  local label="Minimum RSSI"

  if is_true "$enabled"; then
    flag_change
    printf "  ${RED}  ✗ %-${REC_LABEL_WIDTH}s Disabled${RESET}" "$label"
    if [[ "$current" == "$recommended" ]]; then
      printf " ${GREEN}(if enabled %d dBm)${RESET}\n" "$recommended"
    else
      printf " ${RED}(if enabled %d dBm)${RESET}\n" "$recommended"
    fi
  else
    printf "  ${GREEN}  ✓ %-${REC_LABEL_WIDTH}s Disabled${RESET}\n" "$label"
  fi
}

print_rec_interference_blocker() {
  local enabled=$1
  local label="Interference Blocker"

  if is_true "$enabled"; then
    flag_change
    printf "  ${RED}  ✗ %-${REC_LABEL_WIDTH}s Disabled${RESET}\n" "$label"
  else
    printf "  ${GREEN}  ✓ %-${REC_LABEL_WIDTH}s Disabled${RESET}\n" "$label"
  fi
}

# print_rec_roaming  recommended roam_enabled current_roam_rssi
print_rec_roaming() {
  local recommended=$1 roam_enabled=$2 current_roam_rssi=$3
  local label="Roaming Assistant"

  if ! is_true "$roam_enabled"; then
    flag_change
    printf "  ${RED}  ✗ %-${REC_LABEL_WIDTH}s Enabled, %d dBm${RESET}\n" \
      "$label" "$recommended"
    return
  fi

  if (( recommended != current_roam_rssi )); then
    flag_change
    printf "  ${RED}  ✗ %-${REC_LABEL_WIDTH}s Enabled, %d dBm${RESET}\n" \
      "$label" "$recommended"
  else
    printf "  ${GREEN}  ✓ %-${REC_LABEL_WIDTH}s Enabled, %d dBm${RESET}\n" "$label" "$current_roam_rssi"
  fi
}

