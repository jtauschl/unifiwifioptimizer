security_protocol_state() {
  local security=$1 wpa_mode=$2 wpa3_support=$3 wpa3_transition=$4
  local enterprise=false

  case "$security" in
    wpaeap|wpa-enterprise|enterprise) enterprise=true ;;
  esac

  if [[ "$security" == "open" ]]; then
    echo "Open"
  elif [[ "$enterprise" == "true" ]] && is_true "$wpa3_support" && is_true "$wpa3_transition"; then
    echo "WPA2/WPA3 Enterprise"
  elif [[ "$enterprise" == "true" ]] && is_true "$wpa3_support"; then
    echo "WPA3 Enterprise"
  elif [[ "$enterprise" == "true" ]] && [[ "$wpa_mode" == "wpa2" ]]; then
    echo "WPA2 Enterprise"
  elif is_true "$wpa3_support" && is_true "$wpa3_transition"; then
    echo "WPA2/WPA3"
  elif is_true "$wpa3_support"; then
    echo "WPA3"
  elif [[ "$wpa_mode" == "wpa2" ]]; then
    echo "WPA2"
  else
    echo "${security:-Unknown}"
  fi
}

