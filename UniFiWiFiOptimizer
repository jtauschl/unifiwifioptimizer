    printf "  activated the channel before re-running.%s\n" "$RESET"
  fi
  echo
}

ap_scan_prefix() {
  local site=$1 ap=$2
  printf "%s/%s__%s" "$tmpdir" "$(sanitize_token "$site")" "$(sanitize_token "$ap")"
}

