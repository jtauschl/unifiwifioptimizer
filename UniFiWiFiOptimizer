require_profiles_file
load_yaml_config
check_dependencies

print_header
echo "  Detecting environment..."
echo

build_site_inventory
SITE_COUNT=$(wc -l < "$SITES_FILE" | tr -d '[:space:]')

echo "  Scanning access points..."

current_scan_site=""
SITE_SSH_USER=""
SITE_SSH_PASSWORD=""
while IFS=$'\t' read -r site ap mac ip; do
  [[ -z "$site" ]] && continue
  scan_prefix=$(ap_scan_prefix "$site" "$ap")
  scan_err_file="${scan_prefix}.err"

  if [[ "$site" != "$current_scan_site" ]]; then
    load_site_ssh_credentials "$site"
    current_scan_site="$site"
  fi

  echo "    Scanning ${site}/${ap}..."

  if ! ssh_scan_ap "${SITE_SSH_USER}@${ip}" "$SITE_SSH_PASSWORD" > "${scan_prefix}.raw" 2> "$scan_err_file"; then
    : > "${scan_prefix}.raw"
    if [[ -s "$scan_err_file" ]]; then
      printf "    SSH failed: %s\n" "$(tr '\n' ' ' < "$scan_err_file" | sed 's/[[:space:]]\+/ /g; s/^ //; s/ $//')"
    else
      echo "    SSH failed: no details returned"
    fi
    continue
  fi

  awk '/^===5GHZ===/ { exit } { print }' "${scan_prefix}.raw" > "${scan_prefix}.2g"
  awk 'found { print } /^===5GHZ===/ { found=1 }' "${scan_prefix}.raw" > "${scan_prefix}.5g"
done < "$APS_FILE"

echo
echo "  Analyzing recommendations..."
echo

# ============================================================================
# Main: Analysis & Output
# ============================================================================
has_changes=false

while IFS=$'\t' read -r site n env_label _ssh_user _ssh_password; do
  [[ -z "$site" ]] && continue

  # Compute TX corridor for this site from path loss model
  TX_LO=$(awk "BEGIN { printf \"%.0f\", $ROAM_TARGET - 10*$n*log(100/$OVERLAP_DIST)/log(10) }")
  TX_HI=$(( TX_LO + CORRIDOR_WIDTH ))

  if (( SITE_COUNT > 1 )); then
    print_site_header "$site"
  fi

  print_environment_header
  printf "  %-26s %s\n"              "Environment:"            "$env_label"
  printf "  %-26s %d dBm to %d dBm\n" "Target RSSI @ Neighbor:" "$TX_LO" "$TX_HI"
  printf "  %-26s %d dBm\n"           "Roaming Assistant:"      "$ROAM_TARGET"
  printf "  %-26s %d dBm\n"            "Minimum RSSI:"          "$TX_LO"
  echo

  print_general_checks "$site"

  while IFS=$'\t' read -r current_site ap mac ip; do
    [[ "$current_site" != "$site" ]] && continue
    mac2g=$(mac_with_offset "$mac" 1)
    mac5g=$(mac_with_offset "$mac" 2)
    peers="$(get_peers "$site" "$ap")"
    scan_prefix=$(ap_scan_prefix "$site" "$ap")

    # Get current radio info from cached UniFi device data
    # Format: ch24|ht24|tx24|min_tx24|max_tx24|txmode24|min_rssi24|min_rssi_en24|ch5|ht5|tx5|min_tx5|max_tx5|txmode5|min_rssi5|min_rssi_en5|roam_enabled|roam_rssi|ib24|ib5
    radio_info=$(get_radio_info "$site" "$ap")
    IFS='|' read -r \
      ch24 cht24 tx24 min_tx24 max_tx24 txmode24 min_rssi24 min_rssi_en24 \
      ch5 cht5 tx5 min_tx5 max_tx5 txmode5 min_rssi5 min_rssi_en5 \
      roam_enabled roam_rssi ib24 ib5 <<< "$radio_info"

    # Warn if critical radio data is missing from the API
    if [[ -z "$tx24" || -z "$tx5" ]]; then
      printf '  %s  ! Warning: incomplete radio data from API — recommendations may use defaults%s\n' "$RED" "$RESET"
    fi

    # Conservative defaults used only when the API does not expose a field.
    # They keep the report readable, but the warning above should be treated
    # as a sign that the recommendation may be less trustworthy.
    ch24=${ch24:-6};      cht24=${cht24:-20}
    tx24=${tx24:-11};     min_tx24=${min_tx24:-$TX_MIN}; max_tx24=${max_tx24:-$TX_MAX}; txmode24=${txmode24:-custom}
    min_rssi24=${min_rssi24:--75};  min_rssi_en24=${min_rssi_en24:-false}
    ch5=${ch5:-100};      cht5=${cht5:-80}
    tx5=${tx5:-20};       min_tx5=${min_tx5:-$TX_MIN}; max_tx5=${max_tx5:-$TX_MAX}; txmode5=${txmode5:-custom}
    min_rssi5=${min_rssi5:--79};    min_rssi_en5=${min_rssi_en5:-false}
    roam_enabled=${roam_enabled:-false}; roam_rssi=${roam_rssi:-}
    ib24=${ib24:-false}; ib5=${ib5:-false}

    print_ap_header "$ap" "$mac"

    # Pre-compute peer scan prefixes once (reused for both band loops)
    _peer_prefixes=()
    for peer in $peers; do
      _peer_prefixes+=("$(ap_scan_prefix "$site" "$peer")")
    done

    # ══════════ 2.4 GHz ══════════
    print_channel_info "2.4" "$cht24" "$ch24" "$tx24"

    # Collect 2.4 GHz neighbor data (rssi_to = signal from this AP received at neighbor)
    _nbr_peer=(); _nbr_rssi=()
    _sum_rssi24=0; _count_nbr24=0
    _i=0
    for peer in $peers; do
      peer_prefix="${_peer_prefixes[$_i]}"
      _i=$(( _i + 1 ))
      rssi_to=$(get_rssi "$mac2g" "${peer_prefix}.2g")
      if [[ -n "$rssi_to" ]]; then
        _nbr_peer+=("$peer"); _nbr_rssi+=("$rssi_to")
        _sum_rssi24=$(( _sum_rssi24 + rssi_to ))
        _count_nbr24=$(( _count_nbr24 + 1 ))
      fi
    done

    # Compute recommendations
    tx24_uncapped=$tx24
    if [[ $_count_nbr24 -gt 0 ]]; then
      avg_24=$(( _sum_rssi24 / _count_nbr24 ))
      calculate_tx_shift "$avg_24"; shift=$_result
      quantize "$shift"; quantized_shift=$_result
      tx24_uncapped=$(( tx24 + quantized_shift ))
      if (( quantized_shift == 0 )); then
        rec_tx24=$tx24
      else
        cap_tx_power "$tx24_uncapped" "$min_tx24" "$max_tx24"; rec_tx24=$_result
      fi
      # Hysteresis: suppress ±1 dBm changes unless the result hits a hardware limit.
      # Prevents constant small oscillations between runs.
      _delta24=$(( rec_tx24 - tx24 ))
      (( _delta24 < 0 )) && _delta24=$(( -_delta24 ))
      if (( _delta24 <= 1 && rec_tx24 != max_tx24 && rec_tx24 != min_tx24 )); then
        rec_tx24=$tx24
      fi
      calculate_min_rssi_recommendation; rec_rssi24=$_result
    fi

    # Warn only when TX is already at the hardware limit and neighbors are still
    # outside the corridor — TX power alone cannot fix the problem at that point.
    _nbr_warn=()
    if [[ $_count_nbr24 -gt 0 ]]; then
      _shift_applied=$(( rec_tx24 - tx24 ))
      if (( tx24_uncapped > max_tx24 )); then
        for _j in "${!_nbr_peer[@]}"; do
          _proj=$(( _nbr_rssi[_j] + _shift_applied ))
          (( _proj < TX_LO )) && _nbr_warn[_j]="lo"
        done
      elif (( tx24_uncapped < min_tx24 )); then
        for _j in "${!_nbr_peer[@]}"; do
          _proj=$(( _nbr_rssi[_j] + _shift_applied ))
          (( _proj > TX_HI )) && _nbr_warn[_j]="hi"
        done
      fi
    fi

    # Print neighbor table; star marks neighbors still outside the corridor after rec_tx
    print_neighbor_header
    for _j in "${!_nbr_peer[@]}"; do
      _starred=""
      [[ "${_nbr_warn[$_j]:-}" != "" ]] && _starred="*"
      print_neighbor_row "${_nbr_peer[$_j]}" "${_nbr_rssi[$_j]}" "$_starred"
    done

    # Per-neighbor warnings below the table
    _warn_lo=""; _warn_hi=""
    for _j in "${!_nbr_peer[@]}"; do
      case "${_nbr_warn[$_j]:-}" in
        lo) _warn_lo+="${_nbr_peer[$_j]} " ;;
        hi) _warn_hi+="${_nbr_peer[$_j]} " ;;
      esac
    done
    if [[ -n "$_warn_lo" ]]; then
      printf "\n  ${YELLOW}* Coverage gap – signal too weak at: %s${RESET}\n" "${_warn_lo% }"
      printf '  %s  Consider repositioning this AP or adding a neighbor AP.%s\n' "$YELLOW" "$RESET"
    fi
    if [[ -n "$_warn_hi" ]]; then
      printf "\n  ${YELLOW}* Excess overlap – signal too strong at: %s${RESET}\n" "${_warn_hi% }"
      printf '  %s  Consider repositioning or removing this AP.%s\n' "$YELLOW" "$RESET"
    fi

    if [[ $_count_nbr24 -gt 0 ]]; then
      print_recommendations_header
      print_rec_tx      "$rec_tx24"   "$txmode24"     "$tx24"
      print_rec_min_rssi "$rec_rssi24" "$min_rssi_en24" "$min_rssi24"
      if is_true "$min_rssi_en24"; then
        print_rec_interference_blocker "$ib24"
      fi
    else
      echo
      echo "  No neighbor data for 2.4 GHz"
    fi

    echo

    # ══════════ 5 GHz ══════════
    print_channel_info "5" "$cht5" "$ch5" "$tx5"

    # Collect 5 GHz neighbor data (rssi_to = signal from this AP received at neighbor)
    _nbr_peer=(); _nbr_rssi=()
    _sum_rssi5=0; _count_nbr5=0
    _i=0
    for peer in $peers; do
      peer_prefix="${_peer_prefixes[$_i]}"
      _i=$(( _i + 1 ))
      rssi_to=$(get_rssi "$mac5g" "${peer_prefix}.5g")
      if [[ -n "$rssi_to" ]]; then
        _nbr_peer+=("$peer"); _nbr_rssi+=("$rssi_to")
        _sum_rssi5=$(( _sum_rssi5 + rssi_to ))
        _count_nbr5=$(( _count_nbr5 + 1 ))
      fi
    done

    # Compute recommendations
    tx5_uncapped=$tx5
    if [[ $_count_nbr5 -gt 0 ]]; then
      avg_5=$(( _sum_rssi5 / _count_nbr5 ))
      calculate_tx_shift "$avg_5"; shift=$_result
      quantize "$shift"; quantized_shift=$_result
      tx5_uncapped=$(( tx5 + quantized_shift ))
      if (( quantized_shift == 0 )); then
        rec_tx5=$tx5
      else
        cap_tx_power "$tx5_uncapped" "$min_tx5" "$max_tx5"; rec_tx5=$_result
      fi
      # Hysteresis: suppress ±1 dBm changes unless the result hits a hardware limit.
      # Prevents constant small oscillations between runs.
      _delta5=$(( rec_tx5 - tx5 ))
      (( _delta5 < 0 )) && _delta5=$(( -_delta5 ))
      if (( _delta5 <= 1 && rec_tx5 != max_tx5 && rec_tx5 != min_tx5 )); then
        rec_tx5=$tx5
      fi
      calculate_min_rssi_recommendation; rec_rssi5=$_result
      roam_recommended=$ROAM_TARGET
    fi

    # Warn only when TX is already at the hardware limit and neighbors are still
    # outside the corridor — TX power alone cannot fix the problem at that point.
    _nbr_warn=()
    if [[ $_count_nbr5 -gt 0 ]]; then
      _shift_applied=$(( rec_tx5 - tx5 ))
      if (( tx5_uncapped > max_tx5 )); then
        for _j in "${!_nbr_peer[@]}"; do
          _proj=$(( _nbr_rssi[_j] + _shift_applied ))
          (( _proj < TX_LO )) && _nbr_warn[_j]="lo"
        done
      elif (( tx5_uncapped < min_tx5 )); then
        for _j in "${!_nbr_peer[@]}"; do
          _proj=$(( _nbr_rssi[_j] + _shift_applied ))
          (( _proj > TX_HI )) && _nbr_warn[_j]="hi"
        done
      fi
    fi

    # Print neighbor table; star marks neighbors still outside the corridor after rec_tx
    print_neighbor_header
    for _j in "${!_nbr_peer[@]}"; do
      _starred=""
      [[ "${_nbr_warn[$_j]:-}" != "" ]] && _starred="*"
      print_neighbor_row "${_nbr_peer[$_j]}" "${_nbr_rssi[$_j]}" "$_starred"
    done

    # Per-neighbor warnings below the table
    _warn_lo=""; _warn_hi=""
    for _j in "${!_nbr_peer[@]}"; do
      case "${_nbr_warn[$_j]:-}" in
        lo) _warn_lo+="${_nbr_peer[$_j]} " ;;
        hi) _warn_hi+="${_nbr_peer[$_j]} " ;;
      esac
    done
    if [[ -n "$_warn_lo" ]]; then
      printf "\n  ${YELLOW}* Coverage gap – signal too weak at: %s${RESET}\n" "${_warn_lo% }"
      printf '  %s  Consider repositioning this AP or adding a neighbor AP.%s\n' "$YELLOW" "$RESET"
    fi
    if [[ -n "$_warn_hi" ]]; then
      printf "\n  ${YELLOW}* Excess overlap – signal too strong at: %s${RESET}\n" "${_warn_hi% }"
      printf '  %s  Consider repositioning or removing this AP.%s\n' "$YELLOW" "$RESET"
    fi

    if [[ $_count_nbr5 -gt 0 ]]; then
      print_recommendations_header
      print_rec_tx      "$rec_tx5"   "$txmode5"     "$tx5"
      print_rec_roaming "$roam_recommended" "$roam_enabled" "$roam_rssi"
      print_rec_min_rssi "$rec_rssi5" "$min_rssi_en5" "$min_rssi5"
      if is_true "$min_rssi_en5"; then
        print_rec_interference_blocker "$ib5"
      fi
    else
      echo
      echo "  No neighbor data for 5 GHz"
    fi

    echo
  done < "$APS_FILE"
done < "$SITES_FILE"

print_footer "$has_changes"

exit 0
