  local label=$1 allowed=$2 current=$3
  local expected_state
  expected_state=$(security_protocol_expected_state "$allowed")

  if security_protocol_allowed "$allowed" "$current"; then
    printf "  ${GREEN}  ✓ %-${GENERAL_LABEL_WIDTH}s %s${RESET}\n" "$label" "$current"
  else
    flag_change
    printf "  ${RED}  ✗ %-${GENERAL_LABEL_WIDTH}s %s${RESET}\n" \
      "$label" "$expected_state"
  fi
}

print_general_check_bands() {
  local label=$1 expected=$2 actual=$3
  local expected_state actual_state
  expected_state=$(wifi_bands_state "$expected")
  actual_state=$(wifi_bands_state "$actual")

  if [[ "$expected" == "$actual" ]]; then
    printf "  ${GREEN}  ✓ %-${GENERAL_LABEL_WIDTH}s %s${RESET}\n" "$label" "$actual_state"
  else
    flag_change
    printf "  ${RED}  ✗ %-${GENERAL_LABEL_WIDTH}s %s${RESET}\n" \
      "$label" "$expected_state"
  fi
}

print_general_check_rekey() {
  local label=$1 expected=$2 current=$3
  local expected_state current_state expected_norm current_norm
  expected_norm=$(normalize_rekey "$expected")
  current_norm=$(normalize_rekey "$current")
  expected_state=$(rekey_state "$expected_norm")
  current_state=$(rekey_state "$current_norm")

  if [[ "$current_norm" == "$expected_norm" ]]; then
    printf "  ${GREEN}  ✓ %-${GENERAL_LABEL_WIDTH}s %s${RESET}\n" "$label" "$current_state"
  else
    flag_change
    printf "  ${RED}  ✗ %-${GENERAL_LABEL_WIDTH}s %s${RESET}\n" \
      "$label" "$expected_state"
  fi
}

print_general_check_missing() {
